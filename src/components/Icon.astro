  x: '<path d="M6 6l12 12M18 6L6 18"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m16.6 16.6 4.4 4.4"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M19.1 4.9l-1.8 1.8M6.7 17.3l-1.8 1.8"/>',
  moon: '<path d="M20.5 12.5A8.5 8.5 0 1 1 11.5 3.5a7 7 0 0 0 9 9Z"/>',
  shield:
    '<path d="M12 3 5.5 5.5v5c0 4.6 2.8 8 6.5 10 3.7-2 6.5-5.4 6.5-10v-5Z"/><path d="m9.2 11.8 2 2 3.8-4.2"/>',
  help: '<circle cx="12" cy="12" r="9"/><path d="M9.4 9.2a2.8 2.8 0 0 1 5.5.8c0 1.9-2.9 2.3-2.9 4"/><path d="M12 17.4h.01"/>',
  external:
    '<path d="M14 5h5v5"/><path d="M19 5l-8 8"/><path d="M18 13.5V17a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.5"/>',
  'chevron-down': '<path d="m6 9.5 6 6 6-6"/>',
  'chevron-right': '<path d="m9.5 6 6 6-6 6"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5.2l3.4 2"/>',
  sparkles:
    '<path d="M12 4l1.8 4.7 4.7 1.8-4.7 1.8L12 17l-1.8-4.7L5.5 10.5l4.7-1.8Z"/><path d="M18.6 15.4l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8Z"/>',
  book: '<path d="M2.5 5.5c2.8-1.4 5.7-1.4 8.5.5 2.9-1.9 5.7-1.9 8.5-.5v13c-2.8-1.4-5.6-1.4-8.5.5-2.8-1.9-5.7-1.9-8.5-.5Z"/><path d="M11 6.2v12.6"/>',
  map: '<path d="M9 4 3.5 6v14L9 18l6 2 5.5-2V4L15 6 9 4Z"/><path d="M9 4v14M15 6v14"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-1.9 5.1-5.1 1.9 1.9-5.1Z"/>',
  activity: '<path d="M3 12h4l3 8 4-16 3 8h4"/>',
  list: '<path d="M9 6h12M9 12h12M9 18h12"/><path d="M4.5 6h.01M4.5 12h.01M4.5 18h.01"/>',
  'arrow-right': '<path d="M4 12h16m-6-6 6 6-6 6"/>',
  'arrow-left': '<path d="M20 12H4m6-6-6 6 6 6"/>',
  'check-circle': '<circle cx="12" cy="12" r="9"/><path d="m8.5 12.2 2.4 2.4 4.6-5"/>',
  quote:
    '<path d="M8.5 6C6 7 4.5 9.2 4.5 12v5h5v-5H7C7 10 7.6 8.8 9 8.2Z"/><path d="M18.5 6C16 7 14.5 9.2 14.5 12v5h5v-5H17c0-2 .6-3.2 2-3.8Z"/>',
  eye: '<path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z"/><circle cx="12" cy="12" r="3"/>',
  film: '<rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="M8 5v14M16 5v14M3 10h5M3 14h5M16 10h5M16 14h5"/>',
  users:
    '<circle cx="9" cy="8.5" r="3.5"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><path d="M15.5 5.6a3.5 3.5 0 0 1 0 5.8"/><path d="M17.5 14.1a5.5 5.5 0 0 1 3 4.9"/>',
} as const;

export type IconName = keyof typeof icons;

interface Props {
  name: IconName;
  class?: string;
  strokeWidth?: number;
}

const { name, class: className = 'size-5', strokeWidth = 1.8 } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={icons[name]}
/>
