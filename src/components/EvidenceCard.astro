---
interface Props {
  title: string;
  chapter: string;
  strength: 'Faible' | 'Modérée' | 'Forte';
  quote?: string;
  href?: string;
}

const { title, chapter, strength, quote, href } = Astro.props;

let strengthClass = 'ev-badge--muted';
if (strength === 'Forte') strengthClass = 'ev-badge--gold';
else if (strength === 'Modérée') strengthClass = 'ev-badge--violet';
---

<div class="ev-card">
  <div class="ev-card__head">
    <div>
      <h4 class="ev-card__title">
        {
          href ? (
            <a href={href} class="ev-card__link">{title}</a>
          ) : (
            title
          )
        }
      </h4>
      <div class="ev-card__chapter">Chapitre {chapter}</div>
    </div>
    <span class={`ev-badge ${strengthClass}`}>Preuve {strength}</span>
  </div>

  {
    quote && (
      <blockquote class="ev-quote">"{quote}"</blockquote>
    )
  }
</div>

<style>
  .ev-card {
    background: color-mix(in srgb, var(--surface) 45%, transparent);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1rem;
    margin: 1rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ev-card__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }
  .ev-card__title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 2px;
    font-family: var(--font-sans);
  }
  .ev-card__link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .ev-card__link:hover {
    color: var(--cyan);
  }
  .ev-card__chapter {
    font-size: 12px;
    color: var(--text-secondary);
  }
  .ev-quote {
    font-size: 13px;
    color: var(--text-secondary);
    font-style: italic;
    border-left: 2px solid var(--border-color);
    padding-left: 0.75rem;
    margin: 0;
  }
  .ev-badge {
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 5px;
    font-weight: 600;
    border: 1px solid;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.4;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ev-badge--gold {
    background: color-mix(in srgb, var(--accent-gold) 12%, transparent);
    color: var(--accent-gold);
    border-color: color-mix(in srgb, var(--accent-gold) 28%, transparent);
  }
  .ev-badge--violet {
    background: color-mix(in srgb, var(--violet) 14%, transparent);
    color: var(--violet-light);
    border-color: color-mix(in srgb, var(--violet) 30%, transparent);
  }
  .ev-badge--muted {
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    color: var(--text-secondary);
    border-color: var(--border-color);
  }
</style>
