---
interface EvidenceItem {
  id: string;
  data: {
    title: string;
    chapter: number;
    type: 'dialogue' | 'visuel' | 'narratif' | 'structure';
    strength: 'majeure' | 'secondaire';
    articles: string[];
    quote?: string;
  };
}

interface Props {
  items: EvidenceItem[];
}

const { items } = Astro.props;

const typeLabels: Record<string, string> = {
  dialogue: 'Dialogue',
  visuel: 'Visuel',
  narratif: 'Narratif',
  structure: 'Structure',
};

const strengthLabels: Record<string, string> = {
  majeure: 'Majeure',
  secondaire: 'Secondaire',
};

const strengthColors: Record<string, string> = {
  majeure: 'var(--accent-gold)',
  secondaire: 'var(--cyan)',
};
---

<section class="mt-8" aria-labelledby="evidence-heading">
  <h3 id="evidence-heading" class="font-sans text-sm uppercase tracking-wider text-textSecondary mb-4 border-b border-borderColor pb-2">
    Preuves clés
  </h3>
  <div class="grid gap-4">
    {items.map((item) => (
      <article
        class="ev-card bg-bgSecondary border border-borderColor p-4 hover:border-cyanDim transition-colors"
        style={{ '--accent-color': strengthColors[item.data.strength] }}
      >
        <div class="flex items-center justify-between gap-2 mb-2">
          <span class="text-xs font-medium uppercase tracking-wider" style={{ color: strengthColors[item.data.strength] }}>
            {strengthLabels[item.data.strength]}
          </span>
          <span class="text-xs text-textSecondary font-mono">Ch. {item.data.chapter}</span>
        </div>
        <h4 class="font-medium text-textMain mb-2">{item.data.title}</h4>
        <div class="flex items-center gap-2 text-xs text-textSecondary mb-2">
          <span class="px-2 py-0.5 rounded border" style={{ borderColor: 'color-mix(in srgb, var(--violet) 30%, transparent)', background: 'color-mix(in srgb, var(--violet) 10%, transparent)' }}>
            {typeLabels[item.data.type]}
          </span>
        </div>
        {item.data.quote && (
          <blockquote class="text-sm text-textSecondary italic border-l-2 pl-3" style={{ borderColor: strengthColors[item.data.strength] }}>
            {item.data.quote}
          </blockquote>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .ev-card {
    border-radius: 10px;
  }
</style>
