---
interface Props {
  lastUpdatedChapter: string;
  editorialStatus?: string;
}

const { lastUpdatedChapter, editorialStatus } = Astro.props;
---

<div class="meta-row">
  <div>Mis à jour après le chapitre {lastUpdatedChapter}</div>
  {editorialStatus && <div class="meta-status">{editorialStatus}</div>}
</div>

<style>
  .meta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 13.5px;
    color: var(--text-secondary);
    padding: 0.75rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    margin: 1.5rem 0;
  }

  .meta-status {
    margin-left: auto;
    color: var(--cyan);
    font-size: 12px;
  }
</style>
