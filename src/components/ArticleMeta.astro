---
interface Props {
  lastUpdatedChapter: string;
}

const { lastUpdatedChapter } = Astro.props;
---

<div class="meta-row">
  <div>MAJ Chapitre {lastUpdatedChapter}</div>
</div>

<style>
  .meta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 13.5px;
    color: var(--text-secondary);
    padding: 0.75rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    margin: 1.5rem 0;
  }
</style>
