---
interface Props {
  certainty: 'Basse' | 'Moyenne' | 'Haute' | 'Confirmée';
  lastUpdatedChapter: string;
  readingTime: string;
}

const { certainty, lastUpdatedChapter, readingTime } = Astro.props;

let badgeClass = 'meta-badge--muted';
if (certainty === 'Confirmée') badgeClass = 'meta-badge--cyan';
else if (certainty === 'Haute') badgeClass = 'meta-badge--gold';
else if (certainty === 'Moyenne') badgeClass = 'meta-badge--violet';
---

<div class="meta-row">
  <div class="meta-row__group">
    <span>Certitude :</span>
    <span class={`meta-badge ${badgeClass}`}>{certainty}</span>
  </div>
  <span class="meta-sep" aria-hidden="true">•</span>
  <div>MAJ Chapitre {lastUpdatedChapter}</div>
  <span class="meta-sep" aria-hidden="true">•</span>
  <div>{readingTime} de lecture</div>
</div>

<style>
  .meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    font-size: 13.5px;
    color: var(--text-secondary);
    padding: 0.75rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
    margin: 1.5rem 0;
  }
  .meta-row__group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .meta-sep {
    color: var(--text-secondary);
    opacity: 0.45;
  }
  .meta-badge {
    @apply inline-flex items-center px-2.5 py-1 rounded-full text-sm font-medium border;
    font-size: 12px;
    line-height: 1.4;
    white-space: nowrap;
  }
  .meta-badge--cyan {
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    color: var(--cyan);
    border-color: color-mix(in srgb, var(--cyan) 28%, transparent);
  }
  .meta-badge--gold {
    background: color-mix(in srgb, var(--accent-gold) 12%, transparent);
    color: var(--accent-gold);
    border-color: color-mix(in srgb, var(--accent-gold) 28%, transparent);
  }
  .meta-badge--violet {
    background: color-mix(in srgb, var(--violet) 14%, transparent);
    color: var(--violet-light);
    border-color: color-mix(in srgb, var(--violet) 30%, transparent);
  }
  .meta-badge--muted {
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    color: var(--text-secondary);
    border-color: var(--border-color);
  }
</style>
