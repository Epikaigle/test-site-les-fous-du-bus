---
interface Props {
  chapter: string;
  title: string;
  effect: string;
  href: string;
}

const { chapter, title, effect, href } = Astro.props;
---

<a href={href} class="chapter-banner">
  <div class="chapter-banner__glow"></div>
  <div class="chapter-banner__content">
    <div class="chapter-banner__info">
      <span class="chapter-banner__badge-chapter">
        Chap {chapter}
      </span>
      <span class="chapter-banner__title">{title}</span>
      <span class="chapter-banner__badge-effect">
        {effect}
      </span>
    </div>
    <span class="chapter-banner__link">
      Voir l'analyse
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
    </span>
  </div>
</a>

<style>
  .chapter-banner {
    position: relative;
    display: block;
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--bg-secondary) 95%, var(--violet) 5%),
      color-mix(in srgb, var(--bg-secondary) 90%, var(--cyan-dim) 10%)
    );
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: 16px 20px;
    margin-bottom: 48px;
    text-decoration: none;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .chapter-banner:hover {
    border-color: color-mix(in srgb, var(--cyan-dim) 40%, var(--border-color));
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2), 0 0 16px var(--glow-cyan);
  }

  .chapter-banner__glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, var(--cyan), var(--violet));
    border-radius: 3px 0 0 3px;
  }

  .chapter-banner__content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  .chapter-banner__info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .chapter-banner__badge-chapter {
    @apply inline-flex items-center px-2.5 py-1 rounded-full text-sm font-medium border;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background-color: color-mix(in srgb, var(--cyan) 12%, transparent);
    color: var(--cyan);
    border-color: color-mix(in srgb, var(--cyan) 25%, transparent);
    white-space: nowrap;
  }

  .chapter-banner__title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-main);
    transition: color 0.2s ease;
  }

  .chapter-banner:hover .chapter-banner__title {
    color: var(--cyan);
  }

  .chapter-banner__badge-effect {
    @apply inline-flex items-center px-2.5 py-1 rounded-full text-sm font-medium border;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    background-color: color-mix(in srgb, var(--violet) 12%, transparent);
    color: var(--violet-light);
    border-color: color-mix(in srgb, var(--violet) 30%, transparent);
    white-space: nowrap;
  }

  .chapter-banner__link {
    font-size: 13.5px;
    color: var(--text-secondary);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: all 0.2s ease;
  }

  .chapter-banner:hover .chapter-banner__link {
    color: var(--cyan);
  }

  .chapter-banner__link svg {
    transition: transform 0.2s ease;
  }

  .chapter-banner:hover .chapter-banner__link svg {
    transform: translateX(3px);
  }

  @media (max-width: 480px) {
    .chapter-banner {
      padding: 12px 14px;
    }
    .chapter-banner__title {
      font-size: 14px;
    }
    .chapter-banner__link {
      font-size: 13px;
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>
