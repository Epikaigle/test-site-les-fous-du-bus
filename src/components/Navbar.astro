---
import SearchModal from './SearchModal.tsx';
import SidebarNav from './SidebarNav.astro';
---

<nav
  class="navbar"
>
  <!-- Logo -->
  <a
    href="/"
    class="logo"
  >
    <div class="logo-icon">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg
      >
    </div>
    <span class="logo-text hidden sm:inline">Les Fous du Bus</span>
    <span class="logo-text sm:hidden">LFDB</span>
  </a>

  <!-- Desktop nav links -->
  <div class="nav-links">
    <a href="/theorie" class="nav-link">La théorie</a>
    <a href="/dossiers" class="nav-link">Dossiers</a>
    <a href="/chapitres" class="nav-link">Chapitres</a>
    <a href="/explorer" class="nav-link">Explorer</a>
    <a href="/verifier" class="nav-link">Vérifier</a>
  </div>

  <!-- Spacer for mobile -->
  <div class="flex-1 md:hidden"></div>

  <!-- Desktop search + dernière analyse -->
  <div class="nav-actions">
    <a
      href="/chapitres/derniere-analyse"
      class="nav-cta"
      >Dernière analyse</a
    >
    <button
      onclick="window.dispatchEvent(new Event('openSearch'))"
      class="search-trigger"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <span>Rechercher...</span>
      <span class="search-shortcut">Ctrl K</span>
    </button>
  </div>

  <SearchModal client:idle />

  <!-- Mobile search button -->
  <button
    onclick="window.dispatchEvent(new Event('openSearch'))"
    class="mobile-btn"
    aria-label="Rechercher"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg
    >
  </button>

  <!-- Theme toggle -->
  <button
    id="theme-toggle"
    class="mobile-btn"
    aria-label="Changer le thème"
  >
    <svg
      id="theme-icon-dark"
      class="hidden"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
    >
    <svg
      id="theme-icon-light"
      class="hidden"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
        x1="12"
        y1="21"
        x2="12"
        y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
        x1="18.36"
        y1="18.36"
        x2="19.78"
        y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
        x1="21"
        y1="12"
        x2="23"
        y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
        x1="18.36"
        y1="5.64"
        x2="19.78"
        y2="4.22"></line></svg
    >
  </button>

  <!-- Mobile hamburger -->
  <button
    id="mobile-menu-toggle"
    class="mobile-btn"
    aria-label="Menu"
  >
    <svg
      id="hamburger-icon"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line
        x1="3"
        y1="18"
        x2="21"
        y2="18"></line></svg
    >
    <svg
      id="close-icon"
      class="hidden"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg
    >
  </button>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden md:hidden"
  style="top: 52px;"
>
</div>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu-drawer"
  class="fixed top-[52px] left-0 bottom-0 w-[280px] bg-bgMain border-r border-white/10 z-40 overflow-y-auto hidden md:hidden transform -translate-x-full transition-transform duration-300 ease-in-out"
>
  <div class="p-5">
    <!-- Mobile nav links -->
    <div class="mb-6 pb-4 border-b border-white/10">
      <div class="flex flex-col gap-1">
        <a
          href="/theorie"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >La théorie</a
        >
        <a
          href="/dossiers"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Dossiers</a
        >
        <a
          href="/chapitres"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Chapitres</a
        >
        <a
          href="/explorer"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Explorer</a
        >
        <a
          href="/verifier"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Vérifier</a
        >
      </div>
    </div>

    <!-- Sidebar nav content -->
    <SidebarNav currentPath={Astro.url.pathname} />
  </div>
</div>

<style>
  .navbar {
    height: 52px;
    background-color: color-mix(in srgb, var(--bg-main) 80%, transparent);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    padding: 0 16px;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  @media (min-width: 768px) {
    .navbar {
      height: 48px;
      padding: 0 24px;
    }
  }

  /* Logo */
  .logo {
    font-weight: 600;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    margin-right: 24px;
    text-decoration: none;
    color: var(--text-main);
    flex-shrink: 0;
  }

  .logo-icon {
    color: var(--cyan);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--cyan) 20%, transparent);
    transition: all 0.25s ease;
  }

  .logo:hover .logo-icon {
    background: color-mix(in srgb, var(--cyan) 20%, transparent);
    box-shadow: 0 0 12px var(--glow-cyan);
    border-color: color-mix(in srgb, var(--cyan) 40%, transparent);
  }

  .logo-text {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Desktop nav links */
  .nav-links {
    display: none;
    gap: 20px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    font-size: 13px;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 4px 0;
    position: relative;
    transition: color 0.2s ease;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gradient-border);
    border-radius: 1px;
    transition: width 0.25s ease;
  }

  .nav-link:hover {
    color: var(--text-main);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Desktop actions */
  .nav-actions {
    display: none;
    align-items: center;
    gap: 10px;
    margin-left: auto;
  }

  @media (min-width: 768px) {
    .nav-actions {
      display: flex;
    }
  }

  .nav-cta {
    font-size: 12px;
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 5px 10px;
    transition: all 0.2s ease;
  }

  .nav-cta:hover {
    color: var(--cyan);
    border-color: var(--cyan-dim);
    box-shadow: 0 0 12px var(--glow-cyan);
  }

  .search-trigger {
    display: flex;
    align-items: center;
    background-color: color-mix(in srgb, var(--bg-secondary) 80%, transparent);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 5px 10px;
    font-size: 13px;
    color: var(--text-secondary);
    gap: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .search-trigger:hover {
    border-color: var(--violet);
    box-shadow: 0 0 12px var(--glow-violet);
  }

  .search-shortcut {
    background-color: var(--bg-main);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 11px;
    border: 1px solid var(--border-color);
    font-family: monospace;
  }

  /* Mobile button */
  .mobile-btn {
    color: var(--text-secondary);
    padding: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .mobile-btn:hover {
    color: var(--text-main);
  }

  @media (min-width: 768px) {
    .mobile-btn {
      display: none;
    }
  }
</style>

<script>
  // Theme toggle
  const handleToggleClick = () => {
    const element = document.documentElement;
    const isDark = element.classList.contains('dark');

    if (isDark) {
      element.classList.remove('dark');
      element.classList.add('light');
      localStorage.setItem('theme', 'light');
    } else {
      element.classList.remove('light');
      element.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateThemeIcon();
  };

  const updateThemeIcon = () => {
    const isDark = document.documentElement.classList.contains('dark');
    const darkIcon = document.getElementById('theme-icon-dark');
    const lightIcon = document.getElementById('theme-icon-light');
    if (darkIcon && lightIcon) {
      if (isDark) {
        darkIcon.classList.add('hidden');
        lightIcon.classList.remove('hidden');
      } else {
        lightIcon.classList.add('hidden');
        darkIcon.classList.remove('hidden');
      }
    }
  };

  document.getElementById('theme-toggle')?.addEventListener('click', handleToggleClick);
  updateThemeIcon();

  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const menuDrawer = document.getElementById('mobile-menu-drawer');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  const isMenuOpen = () => !menuDrawer?.classList.contains('-translate-x-full');

  const openMenu = () => {
    menuOverlay?.classList.remove('hidden');
    menuDrawer?.classList.remove('hidden');
    requestAnimationFrame(() => {
      menuDrawer?.classList.remove('-translate-x-full');
    });
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    menuDrawer?.classList.add('-translate-x-full');
    menuOverlay?.classList.add('hidden');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    document.body.style.overflow = '';
    setTimeout(() => {
      if (isMenuOpen() === false) {
        menuDrawer?.classList.add('hidden');
      }
    }, 300);
  };

  menuToggle?.addEventListener('click', () => {
    if (isMenuOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  menuOverlay?.addEventListener('click', closeMenu);

  document.querySelectorAll('#mobile-menu-drawer a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isMenuOpen()) {
      closeMenu();
    }
  });
</script>
