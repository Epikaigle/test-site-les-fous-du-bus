---
import SearchModal from './SearchModal.tsx';
import SidebarNav from './SidebarNav.astro';

interface SubLink {
  label: string;
  href: string;
}
interface SubGroup {
  title: string;
  links: SubLink[];
}
interface NavItem {
  label: string;
  href: string;
  groups: SubGroup[];
}

const nav: NavItem[] = [
  {
    label: 'La théorie',
    href: '/theorie',
    groups: [
      {
        title: 'Lire',
        links: [
          { label: 'Résumé de la théorie', href: '/theorie/resume' },
          { label: 'Théorie complète', href: '/theorie/theorie-complete' },
          { label: 'Chronologie', href: '/theorie/chronologie' },
        ],
      },
      {
        title: 'Outils',
        links: [
          { label: 'Carte mentale', href: '/explorer/carte-mentale' },
          { label: 'Lexique essentiel', href: '/aide/glossaire' },
        ],
      },
    ],
  },
  {
    label: 'Dossiers',
    href: '/dossiers',
    groups: [
      {
        title: 'Thématiques',
        links: [
          { label: 'Monde et destinations', href: '/dossiers#monde-destinations' },
          { label: 'Histoire et temporalité', href: '/dossiers#histoire-temporalite' },
          { label: 'Figures principales', href: '/dossiers#figures-principales' },
          { label: 'Armes antiques', href: '/dossiers#armes-antiques' },
          { label: 'Technologies et pouvoirs', href: '/dossiers#technologies-pouvoirs' },
          { label: 'Gouvernement & guerre finale', href: '/dossiers#gouvernement-mondial' },
        ],
      },
    ],
  },
  {
    label: 'Chapitres',
    href: '/chapitres',
    groups: [
      {
        title: 'Dernières analyses',
        links: [
          { label: 'Chapitre 1188', href: '/chapitres/1188' },
          { label: 'Chapitre 1187', href: '/chapitres/1187' },
          { label: 'Chapitre 1186', href: '/chapitres/1186' },
          { label: 'Chapitre 1184', href: '/chapitres/1184' },
        ],
      },
      {
        title: 'Tout voir',
        links: [{ label: 'Tous les chapitres', href: '/chapitres' }],
      },
    ],
  },
  {
    label: 'Explorer',
    href: '/explorer',
    groups: [
      {
        title: 'Explorer',
        links: [
          { label: 'Vue d’ensemble', href: '/explorer' },
          { label: 'Carte mentale', href: '/explorer/carte-mentale' },
          { label: 'Chronologie', href: '/theorie/chronologie' },
        ],
      },
    ],
  },
  {
    label: 'Vérifier',
    href: '/verifier',
    groups: [
      {
        title: 'Méthode',
        links: [
          { label: 'Preuves', href: '/verifier/preuves' },
          { label: 'Citations', href: '/verifier/citations' },
          { label: 'Parallèles', href: '/verifier/paralleles' },
          { label: 'Objections', href: '/verifier/objections' },
          { label: 'Contradictions', href: '/verifier/contradictions' },
          { label: 'Sources', href: '/verifier/sources' },
        ],
      },
    ],
  },
];

// Active top-level section, resolved at build time per page
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<nav class="navbar">
  <!-- Logo -->
  <a href="/" class="logo">
    <div class="logo-icon">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="5" width="20" height="11" rx="2.5"></rect>
        <line x1="2" y1="10.5" x2="22" y2="10.5"></line>
        <line x1="9" y1="5" x2="9" y2="10.5"></line>
        <line x1="15" y1="5" x2="15" y2="10.5"></line>
        <circle cx="7" cy="18.5" r="1.6"></circle>
        <circle cx="17" cy="18.5" r="1.6"></circle>
      </svg>
    </div>
    <span class="logo-text hidden sm:inline">Les Fous du Bus</span>
    <span class="logo-text sm:hidden">LFDB</span>
  </a>

  <!-- Desktop nav links with dropdowns -->
  <div class="nav-links">
    {
      nav.map((item) => (
        <div class="nav-item">
          <a
            href={item.href}
            class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
            aria-haspopup="true"
            aria-current={isActive(item.href) ? 'true' : undefined}
          >
            {item.label}
            <svg class="nav-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </a>
          <div class="nav-dropdown" role="menu">
            {item.groups.map((group) => (
              <div class="nav-dropdown__group">
                <div class="nav-dropdown__title">{group.title}</div>
                {group.links.map((link) => (
                  <a href={link.href} class="nav-dropdown__link" role="menuitem">{link.label}</a>
                ))}
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <div class="flex-1 lg:hidden"></div>

  <!-- Desktop actions -->
  <div class="nav-actions">
    <button
      onclick="window.dispatchEvent(new Event('openSearch'))"
      class="search-trigger"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <span>Rechercher…</span>
      <span class="search-shortcut">Ctrl K</span>
    </button>

    <button data-theme-toggle class="theme-btn theme-btn--desktop" aria-label="Changer le thème">
      <svg class="ico-sun hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
      <svg class="ico-moon hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
    </button>
  </div>

  <!-- Mobile: search -->
  <button
    onclick="window.dispatchEvent(new Event('openSearch'))"
    class="icon-btn"
    aria-label="Rechercher"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
  </button>

  <!-- Mobile: theme toggle -->
  <button data-theme-toggle class="icon-btn theme-btn--mobile" aria-label="Changer le thème">
    <svg class="ico-sun hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
    <svg class="ico-moon hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
  </button>

  <!-- Mobile: hamburger -->
  <button id="mobile-menu-toggle" class="icon-btn" aria-label="Menu" aria-expanded="false">
    <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    <svg id="close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>
</nav>

<!--
  Search modal: MUST live outside <nav>.
  The navbar uses backdrop-filter, which creates a containing block for
  fixed-position descendants — rendered inside the nav, the fixed overlay
  would only cover the 56px bar instead of the whole viewport.
-->
<SearchModal client:idle />

<!-- Mobile menu overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden lg:hidden"
  style="top: var(--nav-h);"
></div>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu-drawer"
  class="fixed left-0 bottom-0 w-[84%] max-w-[320px] bg-bgMain border-r border-borderColor z-40 overflow-y-auto hidden lg:hidden transform -translate-x-full transition-transform duration-300 ease-in-out"
  style="top: var(--nav-h);"
>
  <div class="p-5">
    <div class="mb-5 pb-4 border-b border-borderColor">
      <div class="flex flex-col gap-1">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
              >{item.label}</a
            >
          ))
        }
      </div>
    </div>
    <SidebarNav currentPath={Astro.url.pathname} />
  </div>
</div>

<style>
  .navbar {
    height: var(--nav-h);
    background-color: color-mix(in srgb, var(--bg-main) 82%, transparent);
    backdrop-filter: blur(16px) saturate(1.35);
    -webkit-backdrop-filter: blur(16px) saturate(1.35);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 16px;
    position: sticky;
    top: 0;
    z-index: 50;
    animation: nav-fade-in 0.4s ease-out;
  }

  @keyframes nav-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* Desktop: 3-column grid truly centers the links (logo left, links center, actions right) */
  @media (min-width: 1024px) {
    .navbar {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      padding: 0 28px;
      gap: 12px;
    }
  }

  /* Logo */
  .logo {
    font-weight: 700;
    font-size: 15.5px;
    display: flex;
    align-items: center;
    gap: 9px;
    margin-right: 8px;
    text-decoration: none;
    color: var(--text-main);
    flex-shrink: 0;
  }

  @media (min-width: 1024px) {
    .logo {
      margin-right: 0;
      justify-self: start;
    }
  }

  .logo-icon {
    color: var(--accent-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent-gold) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 24%, transparent);
    transition: all 0.25s ease;
  }

  .logo:hover .logo-icon {
    background: color-mix(in srgb, var(--accent-gold) 22%, transparent);
    box-shadow: 0 0 12px var(--glow-violet);
    transform: translateY(-1px);
  }

  .logo-text {
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Desktop nav links + dropdowns */
  .nav-links {
    display: none;
    gap: 4px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
      justify-self: center;
    }
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 8px 14px;
    border-radius: 8px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    position: relative;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  /* Animated gradient underline (hover + active section) */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 5px;
    height: 2px;
    border-radius: 2px;
    background: var(--gradient-border);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0.9;
    pointer-events: none;
  }

  .nav-link:hover {
    color: var(--text-main);
    background: color-mix(in srgb, var(--surface) 55%, transparent);
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    transform: scaleX(1);
  }

  .nav-link--active {
    color: var(--text-main);
    background: color-mix(in srgb, var(--violet) 12%, transparent);
  }

  .nav-link--active::after {
    transform: scaleX(1);
  }

  .nav-caret {
    opacity: 0.6;
    transition: transform 0.25s ease;
  }

  .nav-item:hover .nav-caret,
  .nav-item:focus-within .nav-caret {
    transform: rotate(180deg);
    opacity: 1;
  }

  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 6px;
    min-width: 240px;
    display: flex;
    gap: 20px;
    padding: 14px 16px;
    background-color: color-mix(in srgb, var(--bg-secondary) 92%, transparent);
    backdrop-filter: blur(16px) saturate(1.3);
    -webkit-backdrop-filter: blur(16px) saturate(1.3);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    box-shadow: 0 16px 40px color-mix(in srgb, var(--bg-main) 50%, transparent);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition:
      opacity 0.22s ease,
      transform 0.22s ease,
      visibility 0.22s;
    z-index: 60;
  }

  /* Invisible bridge so the menu doesn't close when moving the cursor down */
  .nav-dropdown::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
  }

  .nav-item:hover .nav-dropdown,
  .nav-item:focus-within .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown__group {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 150px;
  }

  .nav-dropdown__title {
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    color: var(--text-secondary);
    font-weight: 700;
    padding: 4px 8px 6px;
    font-family: var(--font-sans);
  }

  .nav-dropdown__link {
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 7px 9px;
    border-radius: 7px;
    transform: translateX(0);
    transition: background-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .nav-dropdown__link:hover {
    background: color-mix(in srgb, var(--violet) 14%, transparent);
    color: var(--text-main);
    transform: translateX(3px);
  }

  /* Desktop actions */
  .nav-actions {
    display: none;
    align-items: center;
    gap: 8px;
  }

  @media (min-width: 1024px) {
    .nav-actions {
      display: flex;
      justify-self: end;
    }
  }

  .search-trigger {
    display: flex;
    align-items: center;
    background-color: color-mix(in srgb, var(--bg-secondary) 80%, transparent);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 7px 11px;
    font-size: 13.5px;
    color: var(--text-secondary);
    gap: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .search-trigger:hover {
    border-color: var(--cyan-dim);
    color: var(--text-main);
    box-shadow: 0 0 14px var(--glow-cyan);
    transform: translateY(-1px);
  }

  .search-shortcut {
    background-color: var(--bg-main);
    padding: 1px 6px;
    border-radius: 4px;
    font-size: 11.5px;
    border: 1px solid var(--border-color);
    font-family: monospace;
  }

  /* Theme buttons */
  .theme-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--bg-secondary) 80%, transparent);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .theme-btn:hover {
    color: var(--accent-gold);
    border-color: color-mix(in srgb, var(--accent-gold) 40%, var(--border-color));
  }
  .theme-btn--desktop {
    display: none;
  }
  @media (min-width: 1024px) {
    .theme-btn--desktop {
      display: flex;
    }
  }

  /* Generic icon button (mobile) */
  .icon-btn {
    color: var(--text-secondary);
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .icon-btn:hover {
    color: var(--text-main);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
  }
  .theme-btn--mobile {
    display: flex;
    background: none;
    border: none;
  }

  @media (min-width: 1024px) {
    .icon-btn {
      display: none;
    }
  }
</style>

<script>
  // ---- Theme toggle (desktop + mobile) ----
  const isDark = () => document.documentElement.classList.contains('dark');

  const updateThemeIcons = () => {
    const dark = isDark();
    document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
      const sun = btn.querySelector('.ico-sun');
      const moon = btn.querySelector('.ico-moon');
      if (sun && moon) {
        sun.classList.toggle('hidden', !dark);
        moon.classList.toggle('hidden', dark);
      }
    });
  };

  const toggleTheme = () => {
    const el = document.documentElement;
    if (el.classList.contains('dark')) {
      el.classList.remove('dark');
      el.classList.add('light');
      localStorage.setItem('theme', 'light');
    } else {
      el.classList.remove('light');
      el.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateThemeIcons();
  };

  document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', toggleTheme);
  });
  updateThemeIcons();

  // ---- Mobile menu ----
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const menuDrawer = document.getElementById('mobile-menu-drawer');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  const isMenuOpen = () => !menuDrawer?.classList.contains('-translate-x-full');

  const setMenu = (open) => {
    if (!menuDrawer || !menuOverlay) return;
    if (open) {
      menuOverlay.classList.remove('hidden');
      menuDrawer.classList.remove('hidden');
      requestAnimationFrame(() => menuDrawer.classList.remove('-translate-x-full'));
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
      menuToggle?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    } else {
      menuDrawer.classList.add('-translate-x-full');
      menuOverlay.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  };

  menuToggle?.addEventListener('click', () => setMenu(!isMenuOpen()));
  menuOverlay?.addEventListener('click', () => setMenu(false));
  document.querySelectorAll('#mobile-menu-drawer a').forEach((link) => {
    link.addEventListener('click', () => setMenu(false));
  });
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 1024 && isMenuOpen()) setMenu(false);
  });

  // ---- Dropdowns: close on Escape (keyboard) ----
  document.querySelectorAll('.nav-item').forEach((item) => {
    item.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        (document.activeElement as HTMLElement | null)?.blur();
      }
    });
  });
</script>
