---
import Icon from './Icon.astro';
import { lastChapter, siteIdentity } from '../utils/navigation';
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-abyss/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 w-full max-w-[1760px] items-center gap-1.5 px-3 sm:gap-2 sm:px-5">
    {/* Menu latéral (mobile / tablette) */}
    <button type="button" class="btn-icon lg:hidden" data-drawer-open="nav-drawer" aria-label="Ouvrir la navigation" aria-controls="nav-drawer">
      <Icon name="menu" />
    </button>

    {/* Logo → accueil */}
    <a href="/" class="group flex items-center gap-2.5 rounded-lg px-1 py-1" aria-label="Les Fous du Bus — retour à l'accueil">
      <svg viewBox="0 0 48 48" class="size-8 transition-transform duration-300 group-hover:rotate-6" aria-hidden="true">
        <use href="#lf-piece" fill="url(#lf-grad)"></use>
      </svg>
      <span class="hidden flex-col leading-tight min-[420px]:flex">
        <span class="font-display text-[14px] font-bold tracking-[0.16em] text-ink transition-colors group-hover:text-cyan">
          LES FOUS DU BUS
        </span>
        <span class="hidden text-[10px] uppercase tracking-[0.24em] text-mist/60 xl:block">
          {siteIdentity.title}
        </span>
      </span>
    </a>

    <div class="ml-auto flex items-center gap-1.5 sm:gap-2">
      {/* Recherche globale (Ctrl/⌘ + K) */}
      <button
        type="button"
        data-search-open
        class="flex h-9 items-center gap-2 rounded-full border border-line bg-depth/70 pl-3.5 pr-2 text-sm text-mist/75 transition hover:border-cyan/50 hover:text-mist"
        aria-label="Rechercher dans le site (Ctrl+K)"
      >
        <Icon name="search" class="size-4" />
        <span class="hidden md:inline">Rechercher…</span>
        <span class="hidden gap-0.5 md:flex" aria-hidden="true">
          <kbd class="kbd">⌘</kbd><kbd class="kbd">K</kbd>
        </span>
      </button>

      {/* Dernier chapitre analysé */}
      <a
        href={lastChapter.href}
        class="hidden items-center gap-1.5 rounded-full border border-gold/35 bg-gold/10 px-3 py-1.5 text-xs font-semibold text-gold transition hover:bg-gold/15 md:inline-flex"
        title={`Dernier chapitre analysé : ${lastChapter.number} — « ${lastChapter.title} »`}
      >
        <Icon name="sparkles" class="size-3.5" />
        Ch. {lastChapter.number}
      </a>

      {/* Réglage anti-spoilers */}
      <div class="relative" data-popover>
        <button
          type="button"
          class="btn-icon relative"
          data-popover-trigger
          aria-expanded="false"
          aria-label="Réglage anti-spoilers"
          title="Réglage anti-spoilers"
        >
          <Icon name="shield" />
          <span data-spoiler-dot class="absolute right-1 top-1 hidden size-2 rounded-full bg-cyan shadow-[0_0_8px_var(--c-cyan)]" aria-hidden="true"></span>
        </button>
        <div data-popover-panel class="menu-panel hidden w-[21rem] max-w-[calc(100vw-1.5rem)] p-4" role="dialog" aria-label="Réglage anti-spoilers">
          <p class="text-sm font-semibold text-ink">Réglage anti-spoilers</p>
          <p class="mt-1.5 text-xs leading-relaxed text-mist/80">
            Masque les contenus liés aux chapitres que vous n’avez pas encore lus.
            Un contenu masqué reste révélable d’un clic.
          </p>
          <label class="mt-3.5 block text-xs font-medium text-mist" for="spoiler-input">
            J’ai lu jusqu’au chapitre
          </label>
          <div class="mt-1.5 flex gap-2">
            <input id="spoiler-input" data-spoiler-input type="number" min="1" max="9999" inputmode="numeric" placeholder="ex. 1100" class="input" />
            <button type="button" data-spoiler-apply class="btn-primary shrink-0 text-sm">Appliquer</button>
          </div>
          <div class="mt-2.5 flex items-center justify-between gap-2">
            <button type="button" data-spoiler-clear class="text-xs font-medium text-cyan hover:underline">Tout afficher</button>
            <span data-spoiler-state class="text-right text-[11px] text-mist/70">Aucune restriction</span>
          </div>
          <p class="mt-3 border-t border-line pt-2.5 text-[11px] leading-relaxed text-mist/55">
            Aide de navigation, pas protection absolue : les métadonnées peuvent encore
            évoquer les contenus masqués.
          </p>
        </div>
      </div>

      {/* Mode clair / sombre */}
      <button
        type="button"
        class="btn-icon"
        data-theme-toggle
        aria-label="Basculer entre le mode sombre et le mode clair"
        title="Mode clair / sombre"
      >
        <span data-theme-icon="sun"><Icon name="sun" /></span>
        <span data-theme-icon="moon" class="hidden"><Icon name="moon" /></span>
      </button>

      {/* Aide et ressources */}
      <div class="relative" data-popover>
        <button
          type="button"
          class="btn-icon"
          data-popover-trigger
          aria-expanded="false"
          aria-label="Aide et ressources"
          title="Aide et ressources"
        >
          <Icon name="help" />
        </button>
        <div data-popover-panel class="menu-panel hidden w-64 p-1.5">
          <nav aria-label="Aide et ressources">
            <a class="menu-link" href="/aide/faq"><Icon name="help" class="size-4 text-mist/70" />FAQ</a>
            <a class="menu-link" href="/aide/glossaire"><Icon name="book" class="size-4 text-mist/70" />Glossaire</a>
            <a class="menu-link" href="/verifier/sources"><Icon name="check-circle" class="size-4 text-mist/70" />Sources et méthode</a>
            <a class="menu-link" href="/aide/a-propos"><Icon name="compass" class="size-4 text-mist/70" />À propos du projet</a>
          </nav>
          <div class="my-1.5 border-t border-line" role="none"></div>
          <nav aria-label="Liens externes">
            <a class="menu-link" href={siteIdentity.video} target="_blank" rel="noopener noreferrer">
              <Icon name="film" class="size-4 text-mist/70" />Vidéo originale
              <Icon name="external" class="ml-auto size-3.5 text-mist/50" />
            </a>
            <a class="menu-link" href={siteIdentity.repo} target="_blank" rel="noopener noreferrer">
              <Icon name="external" class="size-4 text-mist/70" />Dépôt GitHub
              <Icon name="external" class="ml-auto size-3.5 text-mist/50" />
            </a>
            <a class="menu-link" href={siteIdentity.x} target="_blank" rel="noopener noreferrer">
              <Icon name="users" class="size-4 text-mist/70" />Fou du Bus TV (X)
              <Icon name="external" class="ml-auto size-3.5 text-mist/50" />
            </a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>
