---
import SearchModal from './SearchModal.tsx';
import SidebarNav from './SidebarNav.astro';
---

<nav
  class="h-[52px] md:h-[48px] bg-bgMain border-b border-white/10 flex items-center px-4 md:px-6 sticky top-0 z-50 relative"
>
  <!-- Logo -->
  <a
    href="/"
    class="font-semibold text-[13px] md:text-[14px] flex items-center gap-2 mr-4 md:mr-6 text-textMain shrink-0"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-cyan"
      ><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path></svg
    >
    <span class="hidden sm:inline">Les Fous du Bus</span>
    <span class="sm:hidden">LFDB</span>
  </a>

  <!-- Desktop nav links -->
  <div class="hidden md:flex gap-5 absolute left-1/2 -translate-x-1/2">
    <a href="/theorie" class="text-[13px] text-textSecondary hover:text-textMain transition-colors"
      >La théorie</a
    >
    <a href="/dossiers" class="text-[13px] text-textSecondary hover:text-textMain transition-colors"
      >Dossiers</a
    >
    <a href="/chapitres" class="text-[13px] text-textSecondary hover:text-textMain transition-colors"
      >Chapitres</a
    >
    <a href="/explorer" class="text-[13px] text-textSecondary hover:text-textMain transition-colors"
      >Explorer</a
    >
    <a href="/verifier" class="text-[13px] text-textSecondary hover:text-textMain transition-colors"
      >Vérifier</a
    >
  </div>

  <!-- Spacer for mobile -->
  <div class="flex-1 md:hidden"></div>

  <!-- Desktop search + dernière analyse -->
  <div class="hidden md:flex items-center gap-3 ml-auto">
    <a
      href="/chapitres/derniere-analyse"
      class="text-[12px] text-textSecondary hover:text-cyan transition-colors border border-white/10 rounded px-2.5 py-1 hover:border-violet"
      >Dernière analyse</a
    >
    <button
      onclick="window.dispatchEvent(new Event('openSearch'))"
      class="flex items-center bg-bgSecondary border border-white/10 rounded px-2.5 py-1 text-[13px] text-textSecondary gap-10 cursor-pointer hover:border-violet transition-colors"
    >
      <span>Rechercher...</span>
      <span class="bg-bgMain px-1.5 py-[1px] rounded-[3px] text-[11px] border border-white/10"
        >Ctrl K</span
      >
    </button>
  </div>

  <SearchModal client:load />

  <!-- Mobile search button -->
  <button
    onclick="window.dispatchEvent(new Event('openSearch'))"
    class="md:hidden text-textSecondary hover:text-textMain p-2 flex items-center justify-center"
    aria-label="Rechercher"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg
    >
  </button>

  <!-- Theme toggle -->
  <button
    id="theme-toggle"
    class="text-textSecondary hover:text-textMain transition-colors p-2 flex items-center justify-center"
    aria-label="Changer le thème"
  >
    <svg
      id="theme-icon-dark"
      class="hidden"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
    >
    <svg
      id="theme-icon-light"
      class="hidden"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
        x1="12"
        y1="21"
        x2="12"
        y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
        x1="18.36"
        y1="18.36"
        x2="19.78"
        y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
        x1="21"
        y1="12"
        x2="23"
        y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
        x1="18.36"
        y1="5.64"
        x2="19.78"
        y2="4.22"></line></svg
    >
  </button>

  <!-- Mobile hamburger -->
  <button
    id="mobile-menu-toggle"
    class="md:hidden text-textSecondary hover:text-textMain p-2 flex items-center justify-center"
    aria-label="Menu"
  >
    <svg
      id="hamburger-icon"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line
        x1="3"
        y1="18"
        x2="21"
        y2="18"></line></svg
    >
    <svg
      id="close-icon"
      class="hidden"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      ><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg
    >
  </button>
</nav>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden md:hidden"
  style="top: 52px;"
>
</div>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu-drawer"
  class="fixed top-[52px] left-0 bottom-0 w-[280px] bg-bgMain border-r border-white/10 z-40 overflow-y-auto hidden md:hidden transform -translate-x-full transition-transform duration-300 ease-in-out"
>
  <div class="p-5">
    <!-- Mobile nav links -->
    <div class="mb-6 pb-4 border-b border-white/10">
      <div class="flex flex-col gap-1">
        <a
          href="/theorie"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >La théorie</a
        >
        <a
          href="/dossiers"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Dossiers</a
        >
        <a
          href="/chapitres"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Chapitres</a
        >
        <a
          href="/explorer"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Explorer</a
        >
        <a
          href="/verifier"
          class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
          >Vérifier</a
        >
      </div>
    </div>

    <!-- Sidebar nav content -->
    <SidebarNav currentPath={Astro.url.pathname} />
  </div>
</div>

<script>
  // Theme toggle
  const handleToggleClick = () => {
    const element = document.documentElement;
    const isDark = element.classList.contains('dark');

    if (isDark) {
      element.classList.remove('dark');
      element.classList.add('light');
      localStorage.setItem('theme', 'light');
    } else {
      element.classList.remove('light');
      element.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateThemeIcon();
  };

  const updateThemeIcon = () => {
    const isDark = document.documentElement.classList.contains('dark');
    const darkIcon = document.getElementById('theme-icon-dark');
    const lightIcon = document.getElementById('theme-icon-light');
    if (darkIcon && lightIcon) {
      if (isDark) {
        darkIcon.classList.add('hidden');
        lightIcon.classList.remove('hidden');
      } else {
        lightIcon.classList.add('hidden');
        darkIcon.classList.remove('hidden');
      }
    }
  };

  document.getElementById('theme-toggle')?.addEventListener('click', handleToggleClick);
  updateThemeIcon();

  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const menuOverlay = document.getElementById('mobile-menu-overlay');
  const menuDrawer = document.getElementById('mobile-menu-drawer');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  const isMenuOpen = () => !menuDrawer?.classList.contains('-translate-x-full');

  const openMenu = () => {
    menuOverlay?.classList.remove('hidden');
    menuDrawer?.classList.remove('hidden');
    // Force reflow before removing transform
    requestAnimationFrame(() => {
      menuDrawer?.classList.remove('-translate-x-full');
    });
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    menuDrawer?.classList.add('-translate-x-full');
    menuOverlay?.classList.add('hidden');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    document.body.style.overflow = '';
    // Hide drawer after transition
    setTimeout(() => {
      if (isMenuOpen() === false) {
        menuDrawer?.classList.add('hidden');
      }
    }, 300);
  };

  menuToggle?.addEventListener('click', () => {
    if (isMenuOpen()) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  menuOverlay?.addEventListener('click', closeMenu);

  // Close menu on navigation
  document.querySelectorAll('#mobile-menu-drawer a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close menu on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768 && isMenuOpen()) {
      closeMenu();
    }
  });
</script>
