---
import SearchModal from './SearchModal.tsx';
import SidebarNav from './SidebarNav.astro';

interface SubLink {
  label: string;
  href: string;
}
interface SubGroup {
  title: string;
  links: SubLink[];
}
interface NavItem {
  label: string;
  href: string;
  groups: SubGroup[];
}

const nav: NavItem[] = [
  {
    label: 'La théorie',
    href: '/theorie',
    groups: [
      {
        title: 'Lire',
        links: [
          { label: 'Résumé de la théorie', href: '/theorie/resume' },
          { label: 'Théorie complète', href: '/theorie/theorie-complete' },
          { label: 'Chronologie', href: '/theorie/chronologie' },
        ],
      },
      {
        title: 'Outils',
        links: [
          { label: 'Carte mentale', href: '/explorer/carte-mentale' },
          { label: 'Lexique essentiel', href: '/aide/glossaire' },
        ],
      },
    ],
  },
  {
    label: 'Dossiers',
    href: '/dossiers',
    groups: [
      {
        title: 'Thématiques',
        links: [
          { label: 'Monde et destinations', href: '/dossiers#monde-destinations' },
          { label: 'Histoire et temporalité', href: '/dossiers#histoire-temporalite' },
          { label: 'Figures principales', href: '/dossiers#figures-principales' },
          { label: 'Armes antiques', href: '/dossiers#armes-antiques' },
          { label: 'Technologies et pouvoirs', href: '/dossiers#technologies-pouvoirs' },
          { label: 'Gouvernement & guerre finale', href: '/dossiers#gouvernement-mondial' },
        ],
      },
    ],
  },
  {
    label: 'Chapitres',
    href: '/chapitres',
    groups: [
      {
        title: 'Dernières analyses',
        links: [
          { label: 'Chapitre 1188', href: '/chapitres/1188' },
          { label: 'Chapitre 1187', href: '/chapitres/1187' },
          { label: 'Chapitre 1186', href: '/chapitres/1186' },
          { label: 'Chapitre 1184', href: '/chapitres/1184' },
        ],
      },
      {
        title: 'Tout voir',
        links: [{ label: 'Tous les chapitres', href: '/chapitres' }],
      },
    ],
  },
  {
    label: 'Explorer',
    href: '/explorer',
    groups: [
      {
        title: 'Explorer',
        links: [
          { label: 'Vue d’ensemble', href: '/explorer' },
          { label: 'Carte mentale', href: '/explorer/carte-mentale' },
          { label: 'Chronologie', href: '/theorie/chronologie' },
        ],
      },
    ],
  },
  {
    label: 'Vérifier',
    href: '/verifier',
    groups: [
      {
        title: 'Méthode',
        links: [
          { label: 'Preuves', href: '/verifier/preuves' },
          { label: 'Citations', href: '/verifier/citations' },
          { label: 'Parallèles', href: '/verifier/paralleles' },
          { label: 'Objections', href: '/verifier/objections' },
          { label: 'Contradictions', href: '/verifier/contradictions' },
          { label: 'Sources', href: '/verifier/sources' },
        ],
      },
    ],
  },
];

// Active top-level section, resolved at build time per page
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---

<nav class="navbar">
  <!-- Left: Sidebar toggle button + Brand Logo -->
  <div class="nav-left">
    <button
      id="navbar-sidebar-toggle"
      class="navbar-sidebar-toggle"
      aria-label="Basculer la barre latérale"
      title="Réduire / Ouvrir la barre latérale"
    >
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="9" y1="3" x2="9" y2="21"></line>
      </svg>
    </button>

    <a href="/" class="logo">
      <div class="logo-icon">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="5" width="20" height="11" rx="2.5"></rect>
          <line x1="2" y1="10.5" x2="22" y2="10.5"></line>
          <line x1="9" y1="5" x2="9" y2="10.5"></line>
          <line x1="15" y1="5" x2="15" y2="10.5"></line>
          <circle cx="7" cy="18.5" r="1.6"></circle>
          <circle cx="17" cy="18.5" r="1.6"></circle>
        </svg>
      </div>
      <span class="logo-text font-bold">Les Fous du Bus</span>
    </a>
  </div>

  <!-- Right: Nav links & Actions -->
  <div class="nav-right">
    <!-- Desktop nav links with dropdowns -->
    <div class="nav-links">
      {
        nav.map((item) => (
          <div class="nav-item">
            <a
              href={item.href}
              class:list={['nav-link', { 'nav-link--active': isActive(item.href) }]}
              aria-haspopup="true"
              aria-current={isActive(item.href) ? 'true' : undefined}
            >
              {item.label}
              <svg class="nav-caret" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </a>
            <div class="nav-dropdown" role="menu">
              {item.groups.map((group) => (
                <div class="nav-dropdown__group">
                  <div class="nav-dropdown__title">{group.title}</div>
                  {group.links.map((link) => (
                    <a href={link.href} class="nav-dropdown__link" role="menuitem">{link.label}</a>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Desktop actions -->
    <div class="nav-actions">
      <button
        onclick="window.dispatchEvent(new Event('openSearch'))"
        class="search-trigger"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span class="hidden sm:inline">Rechercher…</span>
        <span class="search-shortcut hidden sm:inline">Ctrl K</span>
      </button>

      <button data-theme-toggle class="theme-btn theme-btn--desktop" aria-label="Changer le thème">
        <svg class="ico-sun hidden" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <svg class="ico-moon hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
    </div>

    <!-- Mobile: hamburger -->
    <button id="mobile-menu-toggle" class="icon-btn lg:hidden" aria-label="Menu" aria-expanded="false">
      <svg id="hamburger-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      <svg id="close-icon" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
</nav>

<!-- Search modal: MUST live outside <nav> -->
<SearchModal client:idle />

<!-- Mobile menu overlay -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden lg:hidden"
  style="top: var(--nav-h);"
></div>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu-drawer"
  class="fixed left-0 bottom-0 w-[84%] max-w-[320px] bg-bgMain border-r border-borderColor z-40 overflow-y-auto hidden lg:hidden transform -translate-x-full transition-transform duration-300 ease-in-out"
  style="top: var(--nav-h);"
>
  <div class="p-5">
    <div class="mb-5 pb-4 border-b border-borderColor">
      <div class="flex flex-col gap-1">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="text-[14px] text-textSecondary hover:text-textMain hover:bg-surface rounded px-3 py-2 transition-colors"
              >{item.label}</a
            >
          ))
        }
      </div>
    </div>
    <SidebarNav currentPath={Astro.url.pathname} />
  </div>
</div>

<style>
  .navbar {
    height: var(--nav-h);
    background-color: color-mix(in srgb, var(--bg-main) 82%, transparent);
    backdrop-filter: blur(16px) saturate(1.35);
    -webkit-backdrop-filter: blur(16px) saturate(1.35);
    border-bottom: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    position: sticky;
    top: 0;
    z-index: 50;
    animation: nav-fade-in 0.4s ease-out;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .navbar-sidebar-toggle {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--surface) 60%, transparent);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .navbar-sidebar-toggle:hover {
    background: var(--surface);
    color: var(--cyan);
    border-color: var(--cyan);
    transform: scale(1.06);
    box-shadow: 0 0 12px var(--glow-cyan);
  }

  /* Logo ("Les Fous du Bus") aligned on the left alongside sidebar button */
  .logo {
    font-weight: 700;
    font-size: 16px;
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    color: var(--text-main);
    white-space: nowrap;
  }

  .logo-icon {
    color: var(--accent-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--accent-gold) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 24%, transparent);
    transition: all 0.25s ease;
  }

  .logo:hover .logo-icon {
    background: color-mix(in srgb, var(--accent-gold) 22%, transparent);
    box-shadow: 0 0 12px var(--glow-violet);
    transform: translateY(-1px);
  }

  .logo-text {
    font-family: var(--font-display);
    letter-spacing: -0.01em;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .nav-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 16px;
    justify-self: end;
  }

  /* Desktop nav links + dropdowns */
  .nav-links {
    display: none;
    gap: 4px;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .nav-links {
      display: flex;
    }
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--text-main);
    background-color: var(--surface);
  }

  .nav-link--active {
    color: var(--cyan);
    font-weight: 600;
  }

  .nav-caret {
    opacity: 0.5;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav-item:hover .nav-caret {
    opacity: 1;
    transform: rotate(180deg);
  }

  /* Dropdown menu */
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 6px;
    min-width: 220px;
    background-color: var(--bgSecondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    padding: 12px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
    z-index: 60;
  }

  .nav-item:hover .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .nav-dropdown__title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    padding: 4px 8px;
    margin-bottom: 4px;
    opacity: 0.7;
  }

  .nav-dropdown__link {
    display: block;
    padding: 6px 10px;
    font-size: 13.5px;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s ease, background-color 0.15s ease, transform 0.15s ease;
  }

  .nav-dropdown__link:hover {
    color: var(--cyan);
    background-color: var(--surface);
    transform: translateX(3px);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    font-size: 13px;
    color: var(--text-secondary);
    background-color: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
  }

  .search-trigger:hover {
    color: var(--text-main);
    border-color: var(--cyan);
    box-shadow: 0 0 10px var(--glow-cyan);
  }

  .search-shortcut {
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    background-color: var(--surface);
    border: 1px solid var(--border-color);
  }

  .theme-btn,
  .icon-btn {
    width: 34px;
    height: 34px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    background-color: color-mix(in srgb, var(--surface) 60%, transparent);
    border: 1px solid var(--border-color);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .theme-btn:hover,
  .icon-btn:hover {
    color: var(--text-main);
    border-color: var(--violet);
    background-color: var(--surface);
  }

  #mobile-menu-toggle {
    display: none;
  }

  @media (max-width: 1023px) {
    #mobile-menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  // Navbar sidebar toggle logic
  const navbarSidebarToggle = document.getElementById('navbar-sidebar-toggle');
  navbarSidebarToggle?.addEventListener('click', () => {
    const isCollapsed = document.documentElement.classList.toggle('sidebar-left-collapsed');
    const container = document.getElementById('sidebar-left-container');
    container?.classList.toggle('collapsed', isCollapsed);
    localStorage.setItem('sidebar-left-collapsed', String(isCollapsed));
  });

  // Theme toggle logic
  const themeBtns = document.querySelectorAll('[data-theme-toggle]');

  const updateIcons = (theme: string) => {
    document.querySelectorAll('.ico-sun').forEach((el) => {
      if (theme === 'dark') el.classList.remove('hidden');
      else el.classList.add('hidden');
    });
    document.querySelectorAll('.ico-moon').forEach((el) => {
      if (theme === 'light') el.classList.remove('hidden');
      else el.classList.add('hidden');
    });
  };

  const currentTheme = document.documentElement.classList.contains('light') ? 'light' : 'dark';
  updateIcons(currentTheme);

  themeBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const nextTheme = isDark ? 'light' : 'dark';

      if (nextTheme === 'light') {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
        document.documentElement.classList.add('dark');
      }

      localStorage.setItem('theme', nextTheme);
      updateIcons(nextTheme);
    });
  });

  // Mobile menu drawer toggle logic
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileOverlay = document.getElementById('mobile-menu-overlay');
  const mobileDrawer = document.getElementById('mobile-menu-drawer');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  const isMobileMenuOpen = () => !mobileDrawer?.classList.contains('-translate-x-full');

  const openMobileMenu = () => {
    mobileOverlay?.classList.remove('hidden');
    mobileDrawer?.classList.remove('hidden');
    requestAnimationFrame(() => {
      mobileDrawer?.classList.remove('-translate-x-full');
    });
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    mobileToggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };

  const closeMobileMenu = () => {
    mobileDrawer?.classList.add('-translate-x-full');
    mobileOverlay?.classList.add('hidden');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    mobileToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => {
      if (!isMobileMenuOpen()) {
        mobileDrawer?.classList.add('hidden');
      }
    }, 300);
  };

  mobileToggle?.addEventListener('click', () => {
    if (isMobileMenuOpen()) {
      closeMobileMenu();
    } else {
      openMobileMenu();
    }
  });

  mobileOverlay?.addEventListener('click', closeMobileMenu);
</script>
