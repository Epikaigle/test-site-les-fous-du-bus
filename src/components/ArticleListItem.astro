---
interface Props {
  badge: string;
  badgeColor: 'cyan' | 'violet' | 'gold';
  title: string;
  category: string;
  chapter: string;
  href: string;
}

const { badge, badgeColor, title, category, chapter, href } = Astro.props;

const colorClasses = {
    cyan: 'bg-cyan/10 text-cyan border-cyan/20',
    violet: 'bg-violet/10 text-[#D3B3FF] border-violet/30',
    gold: 'bg-accentGold/10 text-accentGold border-accentGold/20'
};
---
<a href={href} class="flex flex-col md:flex-row md:items-center justify-between p-3 px-4 bg-bgMain border border-white/10 rounded transition-colors hover:bg-bgSecondary gap-3 md:gap-0">
    <div class="flex items-center gap-3">
        <span class={`text-[11px] px-1.5 py-0.5 rounded-[3px] font-medium border uppercase tracking-[0.5px] shrink-0 ${colorClasses[badgeColor]}`}>
            {badge}
        </span>
        <span class="text-[14px] font-medium text-textMain hover:text-cyan transition-colors">{title}</span>
    </div>
    <div class="text-[12px] text-textSecondary flex gap-3 items-center">
        <span>{category}</span>
        <span class="text-white/20 hidden md:inline">•</span>
        <span>Suite au chap. {chapter}</span>
    </div>
</a>
