---
interface Props {
  badge: string;
  badgeColor: 'cyan' | 'violet' | 'gold';
  title: string;
  category: string;
  chapter: string;
  href: string;
}

const { badge, badgeColor, title, category, chapter, href } = Astro.props;

const colorClasses = {
    cyan: 'bg-cyan/10 text-cyan border-cyan/20',
    violet: 'bg-violet/10 text-[#D3B3FF] border-violet/30',
    gold: 'bg-accentGold/10 text-accentGold border-accentGold/20'
};
---
<a href={href} class="article-item">
    <div class="article-item__main">
        <span class={`article-item__badge ${colorClasses[badgeColor]}`}>
            {badge}
        </span>
        <span class="article-item__title">{title}</span>
    </div>
    <div class="article-item__meta">
        <span>{category}</span>
        <span class="article-item__dot">•</span>
        <span>Suite au chap. {chapter}</span>
    </div>
</a>

<style>
    .article-item {
        display: flex;
        flex-direction: column;
        padding: 12px 16px;
        background-color: var(--bg-main);
        border: 1px solid var(--border-color);
        border-radius: 4px;
        text-decoration: none;
        transition: background-color 0.2s, border-color 0.2s;
        gap: 8px;
    }

    .article-item:hover {
        background-color: var(--bg-secondary);
        border-color: color-mix(in srgb, var(--violet) 30%, var(--border-color));
    }

    .article-item__main {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .article-item__badge {
        font-size: 11px;
        padding: 2px 6px;
        border-radius: 3px;
        font-weight: 500;
        border: 1px solid;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .article-item__title {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-main);
        transition: color 0.2s;
    }

    .article-item:hover .article-item__title {
        color: var(--cyan);
    }

    .article-item__meta {
        font-size: 12px;
        color: var(--text-secondary);
        display: flex;
        gap: 8px;
        align-items: center;
        padding-left: 0;
    }

    .article-item__dot {
        color: rgba(255, 255, 255, 0.2);
    }

    @media (min-width: 768px) {
        .article-item {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 0;
        }
        .article-item__meta {
            padding-left: 0;
        }
    }

    @media (max-width: 480px) {
        .article-item {
            padding: 10px 12px;
        }
        .article-item__title {
            font-size: 13px;
        }
        .article-item__meta {
            font-size: 11px;
            flex-wrap: wrap;
        }
    }
</style>
