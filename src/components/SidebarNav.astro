---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navSections = [
    {
        title: 'Accueil',
        links: [
            { label: 'Le Siècle oublié est le présent', href: '/' }
        ]
    },
    {
        title: 'La théorie',
        links: [
            { label: 'Fondations', href: '/theorie/fondations' },
            { label: 'Figures et identités', href: '/theorie/figures' },
            { label: 'Armes antiques', href: '/theorie/armes' },
            { label: 'Science, énergie et pouvoirs', href: '/theorie/science' },
            { label: 'Monde, peuples et témoins', href: '/theorie/monde' },
            { label: 'Gouvernement et guerre finale', href: '/theorie/gouvernement' },
            { label: 'Chronologie des événements', href: '/theorie/chronologie' }
        ]
    },
    {
        title: 'Explorer',
        links: [
            { label: 'Frises chronologiques', href: '/explorer/frises' },
            { label: 'Carte du monde', href: '/explorer/carte' },
            { label: 'Carte des personnages', href: '/explorer/personnages' },
            { label: 'Schémas temporels', href: '/explorer/schemas' }
        ]
    }
];
---
<nav>
    {navSections.map((section, index) => (
        <div class={index > 0 ? "mt-6" : ""}>
            <h3 class="text-[12px] uppercase tracking-[0.5px] text-textMain mb-3 font-semibold">{section.title}</h3>
            <ul class="list-none space-y-1">
                {section.links.map(link => {
                    const isActive = currentPath === link.href || currentPath === link.href + '/';
                    return (
                        <li>
                            <a 
                                href={link.href} 
                                class={`block px-3 py-1.5 -ml-3 rounded text-[13px] transition-colors ${isActive ? 'text-cyan font-medium bg-cyan/10' : 'text-textSecondary hover:bg-surface hover:text-textMain'}`}
                            >
                                {link.label}
                            </a>
                        </li>
                    )
                })}
            </ul>
        </div>
    ))}
</nav>
