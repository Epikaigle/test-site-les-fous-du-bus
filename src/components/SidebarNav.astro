---

<nav>
  {
    navSections.map((section, index) => {
      const isExpanded = section.links.some(
        (link) => currentPath === link.href || currentPath === link.href + '/',
      );
      return (
        <div class={index > 0 ? 'mt-5' : ''} data-sidebar-section>
          <button
            class="sidebar-section-toggle flex items-center justify-between w-full text-left text-[11px] uppercase tracking-[0.6px] text-textMain mb-2 font-semibold hover:text-cyan transition-colors cursor-pointer"
            aria-expanded={isExpanded ? 'true' : 'false'}
          >
            <span>{section.label}</span>
            <svg
              class="sidebar-chevron w-3 h-3 transition-transform duration-200 shrink-0"
              class:list={[{ 'rotate-90': isExpanded }]}
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
          <ul
            class="sidebar-section-links list-none space-y-0.5 overflow-hidden transition-all duration-200"
            class:list={[{ 'max-h-0 opacity-0': !isExpanded }, { 'max-h-[2000px] opacity-100': isExpanded }]}
          >
            {section.links.map((link) => {
              const isActive = currentPath === link.href || currentPath === link.href + '/';
              return (
                <li>
                  <a
                    href={link.href}
                    class={`sidebar-link block px-3 py-1.5 -ml-1 rounded text-[13px] transition-colors ${
                      isActive
                        ? 'text-cyan font-medium bg-cyan/10'
                        : 'text-textSecondary hover:bg-surface hover:text-textMain'
                    }`}
                  >
                    {link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })
  }
</nav>

<script>
  // Sidebar collapsible sections
  document.querySelectorAll('[data-sidebar-section]').forEach((section) => {
    const toggle = section.querySelector('.sidebar-section-toggle');
    const links = section.querySelector('.sidebar-section-links');
    const chevron = section.querySelector('.sidebar-chevron');

    if (!toggle || !links || !chevron) return;

    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isExpanded));
      chevron.classList.toggle('rotate-90', !isExpanded);
      links.classList.toggle('max-h-0', isExpanded);
      links.classList.toggle('opacity-0', isExpanded);
      links.classList.toggle('max-h-[2000px]', !isExpanded);
      links.classList.toggle('opacity-100', !isExpanded);
    });
  });
</script>
