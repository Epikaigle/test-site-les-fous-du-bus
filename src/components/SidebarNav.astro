---
import { getCollection } from 'astro:content';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// Fetch all published articles
const articles = await getCollection('articles', ({ data }) => data.status === 'published');

// Category mapping with French labels and icons
const categoryConfig: Record<string, { label: string; icon: string; order: number }> = {
  'monde-destinations': { label: 'Monde et destinations', icon: '🌍', order: 1 },
  'histoire-temporalite': { label: 'Histoire, temps et Ponéglyphes', icon: '📜', order: 2 },
  'figures-principales': { label: 'Figures principales', icon: '🎭', order: 3 },
  'personnages-identites': { label: 'Personnages et identités', icon: '👥', order: 4 },
  'armes-antiques': { label: 'Armes antiques', icon: '🔱', order: 5 },
  'technologies-pouvoirs': { label: 'Technologies et pouvoirs', icon: '⚡', order: 6 },
  'peuples-royaumes': { label: 'Peuples, royaumes et témoins', icon: '🏰', order: 7 },
  'dieux-croyances': { label: 'Dieux et croyances', icon: '🙏', order: 8 },
  'transmission-memoire': { label: 'Transmission et mémoire', icon: '🎵', order: 9 },
  'gouvernement-mondial': { label: 'Gouvernement mondial', icon: '⚖️', order: 10 },
  'guerre-finale': { label: 'Guerre finale', icon: '⚔️', order: 11 },
};

// Group articles by category
const articlesByCategory = new Map<string, typeof articles>();
for (const article of articles) {
  const cat = article.data.category;
  if (!articlesByCategory.has(cat)) {
    articlesByCategory.set(cat, []);
  }
  articlesByCategory.get(cat)!.push(article);
}

// Sort categories by order
const sortedCategories = Array.from(articlesByCategory.entries()).sort(
  ([catA], [catB]) => (categoryConfig[catA]?.order ?? 99) - (categoryConfig[catB]?.order ?? 99)
);

// Build navigation sections
interface NavSection {
  title: string;
  label: string;
  icon: string;
  links: Array<{ label: string; href: string }>;
}

const navSections: NavSection[] = [
  {
    title: 'COMMENCER',
    label: 'Commencer',
    icon: '🚀',
    links: [
      { label: 'Présentation', href: '/' },
      { label: 'Résumé de la théorie', href: '/theorie/resume' },
      { label: 'Théorie complète', href: '/theorie/theorie-complete' },
      { label: 'Carte mentale', href: '/explorer/carte-mentale' },
      { label: 'Lexique essentiel', href: '/aide/glossaire' },
    ],
  },
  ...sortedCategories.map(([catKey, catArticles]) => {
    const config = categoryConfig[catKey];
    return {
      title: catKey.toUpperCase().replace(/-/g, ' '),
      label: config?.label ?? catKey,
      icon: config?.icon ?? '📄',
      links: catArticles
        .sort((a, b) => (b.data.lastUpdatedChapter ?? 0) - (a.data.lastUpdatedChapter ?? 0))
        .map((article) => ({
          label: article.data.title,
          href: `/theorie/${article.id}`,
        })),
    };
  }),
];

// Add chapters section
const chapters = await getCollection('chapters');
const sortedChapters = chapters.sort((a, b) => b.data.chapter - a.data.chapter);

navSections.push({
  title: 'CHAPITRES',
  label: 'Chapitres récents',
  icon: '📖',
  links: sortedChapters.slice(0, 10).map((chapter) => ({
    label: `Chapitre ${chapter.data.chapter} — ${chapter.data.title}`,
    href: `/chapitres/${chapter.data.chapter}`,
  })),
});

// Add help section
navSections.push({
  title: 'AIDE',
  label: 'Aide & ressources',
  icon: '❓',
  links: [
    { label: 'À propos', href: '/aide/a-propos' },
    { label: 'FAQ', href: '/aide/faq' },
    { label: 'Glossaire', href: '/aide/glossaire' },
    { label: 'Proposer une correction', href: '/aide/correction' },
    { label: 'Crédits', href: '/aide/credits' },
  ],
});
---

<nav>
  {navSections.map((section, index) => {
    const isExpanded = section.links.some(
      (link) => currentPath === link.href || currentPath === link.href + '/' || (link.href !== '/' && currentPath.startsWith(link.href)),
    );
    return (
      <div class={index > 0 ? 'mt-5' : ''} data-sidebar-section>
        <button
          class="sidebar-section-toggle"
          aria-expanded={isExpanded ? 'true' : 'false'}
        >
          <span class="flex items-center gap-2">
            <span class="text-base">{section.icon}</span>
            <span>{section.label}</span>
          </span>
          <svg
            class="sidebar-chevron"
            class:list={[{ 'rotate-90': isExpanded }]}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            width="12"
            height="12"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
        <ul
          class="sidebar-section-links"
          class:list={[{ 'collapsed': !isExpanded }, { 'expanded': isExpanded }]}
        >
          {section.links.map((link) => {
            const isActive = currentPath === link.href || currentPath === link.href + '/';
            return (
              <li>
                <a
                  href={link.href}
                  class={`sidebar-link ${isActive ? 'sidebar-link--active' : ''}`}
                >
                  {link.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    );
  })}
</nav>

<style>
  .sidebar-section-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    text-align: left;
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--text-main);
    margin-bottom: 8px;
    font-weight: 600;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px 0;
    transition: color 0.2s ease;
  }

  .sidebar-section-toggle:hover {
    color: var(--cyan);
  }

  .sidebar-chevron {
    flex-shrink: 0;
    transition: transform 0.2s ease;
    opacity: 0.6;
  }

  .sidebar-section-toggle:hover .sidebar-chevron {
    opacity: 1;
  }

  .sidebar-section-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    overflow: hidden;
    transition: max-height 0.25s ease, opacity 0.2s ease;
  }

  .sidebar-section-links.collapsed {
    max-height: 0;
    opacity: 0;
  }

  .sidebar-section-links.expanded {
    max-height: 2000px;
    opacity: 1;
  }

  .sidebar-link {
    display: block;
    padding: 5px 12px;
    margin-left: -4px;
    border-radius: 7px;
    font-size: 13.5px;
    text-decoration: none;
    color: var(--text-secondary);
    transition: all 0.15s ease;
    border-left: 2px solid transparent;
  }

  .sidebar-link:hover {
    background-color: color-mix(in srgb, var(--surface) 60%, transparent);
    color: var(--text-main);
    border-left-color: color-mix(in srgb, var(--violet) 40%, transparent);
  }

  .sidebar-link--active {
    color: var(--cyan);
    font-weight: 500;
    background: color-mix(in srgb, var(--cyan) 8%, transparent);
    border-left-color: var(--cyan);
  }

  .sidebar-link--active:hover {
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    border-left-color: var(--cyan);
  }
</style>

<script>
  // Sidebar collapsible sections
  document.querySelectorAll('[data-sidebar-section]').forEach((section) => {
    const toggle = section.querySelector('.sidebar-section-toggle');
    const links = section.querySelector('.sidebar-section-links');
    const chevron = section.querySelector('.sidebar-chevron');

    if (!toggle || !links || !chevron) return;

    const setExpanded = (expanded) => {
      toggle.setAttribute('aria-expanded', String(expanded));
      chevron.classList.toggle('rotate-90', expanded);
      links.classList.toggle('expanded', expanded);
      links.classList.toggle('collapsed', !expanded);
    };

    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
      setExpanded(!isExpanded);
    });
  });
</script>