---
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__left">
      <div class="footer__brand">
        <div class="footer__logo">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-cyan">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
          </svg>
        </div>
        <span class="footer__copyright">© 2026 Les Fous du Bus</span>
      </div>
      <p class="footer__note">Projet fan-made non officiel. One Piece © Eiichiro Oda / Shueisha / Toei Animation.</p>
    </div>

    <div class="footer__right">
      <div class="footer__links">
        <a href="/aide/a-propos">À propos</a>
        <a href="/aide/glossaire">Glossaire</a>
        <a href="/aide/faq">FAQ</a>
        <a href="/aide/correction">Proposer une correction</a>
      </div>
      <div class="footer__social">
        <a
          href="https://github.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__social-link"
          aria-label="GitHub"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a
          href="https://twitter.com"
          target="_blank"
          rel="noopener noreferrer"
          class="footer__social-link"
          aria-label="Twitter"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: 64px;
    padding: 24px 0 28px;
    border-top: 1px solid var(--border-color);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
    }
  }

  .footer__left {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .footer__logo {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer__copyright {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-main);
  }

  .footer__note {
    font-size: 11px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    opacity: 0.7;
  }

  .footer__right {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  @media (min-width: 768px) {
    .footer__right {
      align-items: flex-end;
    }
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer__links a {
    font-size: 12px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__links a:hover {
    color: var(--cyan);
  }

  .footer__social {
    display: flex;
    gap: 8px;
  }

  .footer__social-link {
    width: 32px;
    height: 32px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface) 50%, transparent);
    border: 1px solid var(--border-color);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .footer__social-link:hover {
    color: var(--text-main);
    border-color: var(--violet);
    background: color-mix(in srgb, var(--violet) 12%, transparent);
    box-shadow: 0 0 10px var(--glow-violet);
  }
</style>
