---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
---

<WikiLayout title="Aide" currentPath="/aide">
  <div class="page-header">
    <div class="text-cyan font-semibold tracking-widest uppercase text-sm mb-3">Ressources</div>
    <h1>Aide</h1>
    <p class="page-desc">
      Tout ce qu'il faut savoir pour naviguer sur le site, comprendre la théorie et contribuer au
      projet.
    </p>
  </div>

  <div class="nav-cards">
    <a href="/aide/faq" class="nav-card">
      <span class="nav-card__icon">❓</span>
      <div>
        <h3>FAQ</h3>
        <p>Questions fréquemment posées sur la théorie et le site.</p>
      </div>
    </a>

    <a href="/aide/glossaire" class="nav-card">
      <span class="nav-card__icon">📖</span>
      <div>
        <h3>Glossaire</h3>
        <p>Définitions des termes clés utilisés dans la théorie.</p>
      </div>
    </a>

    <a href="/aide/a-propos" class="nav-card">
      <span class="nav-card__icon">ℹ️</span>
      <div>
        <h3>À propos</h3>
        <p>Le projet, son origine et ses objectifs.</p>
      </div>
    </a>

    <a href="/aide/credits" class="nav-card">
      <span class="nav-card__icon">🙏</span>
      <div>
        <h3>Crédits</h3>
        <p>Attributions et remerciements.</p>
      </div>
    </a>

    <a href="/aide/correction" class="nav-card">
      <span class="nav-card__icon">✏️</span>
      <div>
        <h3>Proposer une correction</h3>
        <p>Signaler une erreur ou proposer une amélioration.</p>
      </div>
    </a>
  </div>

  <Footer />
</WikiLayout>

<style>
  .page-header {
    margin-bottom: 48px;
  }
  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
  }
  .page-desc {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }
  .nav-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px;
  }
  .nav-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px;
    background: var(--gradient-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }
  .nav-card:hover {
    border-color: var(--violet);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px color-mix(in srgb, var(--bg-main) 40%, transparent),
      0 0 18px var(--glow-violet);
  }
  .nav-card__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 2px;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--cyan) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--cyan) 14%, transparent);
  }
  .nav-card h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 4px;
    transition: color 0.2s;
  }
  .nav-card:hover h3 {
    color: var(--cyan);
  }
  .nav-card p {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
</style>
