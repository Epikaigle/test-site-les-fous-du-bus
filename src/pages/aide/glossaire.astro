---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';

interface GlossaryItem {
  term: string;
  canonDef: string;
  theoryDef: string;
}

const glossaryEntries: GlossaryItem[] = [
  {
    term: 'Joy Boy',
    canonDef: 'Figure légendaire du Siècle Oublié mentionnée sur le Ponéglyphe du Royaume Ryūgū, ayant fait une promesse non tenue aux Hommes-Poissons il y a 800 ans.',
    theoryDef: 'Nom ou titre épique que le monde donnera à Monkey D. Luffy après la libération des peuples et l\'accomplissement de la promesse.',
  },
  {
    term: 'Nika',
    canonDef: 'Le « Guerrier de la Libération », Dieu du Soleil réputé faire rire les esclaves et libérer les opprimés dans le folklore ancien.',
    theoryDef: 'Divinisation progressive de la forme éveillée de Luffy (Gear 5), perçue à travers les récits et la foi des peuples libérés.',
  },
  {
    term: 'Laugh Tale',
    canonDef: 'Dernière île de Grand Line nommée par Gol D. Roger, abritant le trésor One Piece et la véritable histoire du Siècle Oublié.',
    theoryDef: 'L\'île ultime n\'est pas séparée dans l\'espace mais dans le temps. C\'est l\'île où la mémoire du monde s\'accomplit.',
  },
  {
    term: 'Flamme Mère (Mother Flame)',
    canonDef: 'Source d\'énergie synthétique créée par le Dr Vegapunk sur Egghead, capable d\'alimenter l\'Arme Antique Uranus.',
    theoryDef: 'Le cœur énergétique synthétisé pour reproduire l\'énergie antique, lié au fonctionnement du robot géant Emeth et à la guerre finale.',
  },
  {
    term: 'Ponéglyphes',
    canonDef: 'Stèles de pierre indestructibles gravées par le clan Kozuki de Wano Kuni pour transmettre l\'histoire oubliée et la localisation de Laugh Tale.',
    theoryDef: 'Textes rédigés non pas dans le passé lointain mais dans le futur par l\'alliance de Luffy, puis transmis vers les époques antérieures.',
  },
  {
    term: 'Le Déluge',
    canonDef: 'Montée des eaux de 200 mètres provoquée lors du Siècle Oublié et réactivée récemment par la destruction de Lulusia.',
    theoryDef: 'Événement cataclysmique ultime qui détruira les frontières naturelles (Red Line) et réunira tous les océans pour former All Blue.',
  },
  {
    term: 'Emeth',
    canonDef: 'Robot géant vieux de 900 ans découvert sur Egghead, éveillé par le rythme des tambours de la libération (Gear 5).',
    theoryDef: 'Création technologique issue du futur et envoyée dans le passé pour sceller le pouvoir de Joy Boy et protéger l\'alliance.',
  },
  {
    term: 'Siècle Oublié',
    canonDef: 'Période de 100 ans effacée de l\'histoire officielle par le Gouvernement Mondial, survenue il y a environ 800 ans.',
    theoryDef: 'Période qui n\'a pas encore eu lieu historiquement : elle correspond à l\'histoire que l\'équipage de Luffy est en train d\'écrire au présent.',
  },
  {
    term: 'Poséidon',
    canonDef: 'L\'une des trois Armes Antiques, incarnée aujourd\'hui par la princesse Sirène Shirahoshi, capable d\'ordonner aux Rois des Mers.',
    theoryDef: 'Pouvoir de la princesse des mers dont l\'éveil était prévu pour coïncider avec la venue de Joy Boy (Luffy).',
  },
  {
    term: 'Pluton',
    canonDef: 'Arme Antique décrite comme un navire de guerre dévastateur, actuellement scellée sous les fondations de Wano Kuni.',
    theoryDef: 'Navire cuirassé gigantesque lié à la transformation de Water Seven et à la réouverture des frontières de Wano.',
  },
  {
    term: 'Imu Nerona',
    canonDef: 'Souverain occulte siégeant sur le Trône Vacant de Mary Geoise et commandant au Gorosei dans le plus grand secret.',
    theoryDef: 'L\'antagoniste ultime cherchant à figer le monde dans un statut immuable pour contrer l\'inévitable libération.',
  },
];

// Sort alphabetically
glossaryEntries.sort((a, b) => a.term.localeCompare(b.term, 'fr'));

// Group by first letter
const grouped: Record<string, typeof glossaryEntries> = {};
glossaryEntries.forEach((entry) => {
  const letter = entry.term.charAt(0).toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(entry);
});
const sortedLetters = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'fr'));
---

<WikiLayout title="Glossaire" currentPath="/aide/glossaire">
  <div class="page-header">
    <h1>Glossaire</h1>
    <p class="page-desc">
      Définitions rigoureuses des termes clés. Chaque notion distingue clairement les éléments canons du manga des hypothèses proposées par la théorie.
    </p>
  </div>

  <!-- Alphabet navigation -->
  <div class="alpha-nav">
    {
      sortedLetters.map((letter) => (
        <a href={`#letter-${letter}`} class="alpha-link">
          {letter}
        </a>
      ))
    }
  </div>

  <!-- Glossary entries -->
  {
    sortedLetters.map((letter) => (
      <div class="letter-section" id={`letter-${letter}`}>
        <h2 class="letter-title">{letter}</h2>
        <div class="entries">
          {grouped[letter].map((entry) => (
            <div class="entry-card">
              <h3 class="entry-term">{entry.term}</h3>
              <div class="entry-blocks">
                <div class="entry-block entry-block--canon">
                  <span class="block-label">Dans le manga</span>
                  <p>{entry.canonDef}</p>
                </div>
                <div class="entry-block entry-block--theory">
                  <span class="block-label">Selon la théorie</span>
                  <p>{entry.theoryDef}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))
  }

  <Footer />
</WikiLayout>

<style>
  .page-header {
    margin-bottom: 32px;
  }
  .page-header h1 {
    font-size: clamp(1.5rem, 4vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 12px;
  }
  .page-desc {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 680px;
  }

  .alpha-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 36px;
    padding: 12px 16px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
  }

  .alpha-link {
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .alpha-link:hover {
    background-color: var(--surface);
    color: var(--cyan);
    transform: translateY(-2px);
  }

  .letter-section {
    margin-bottom: 36px;
    scroll-margin-top: calc(var(--nav-h) + 16px);
  }

  .letter-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--violet);
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
  }

  .entries {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .entry-card {
    padding: 20px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
  }

  .entry-term {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 14px;
  }

  .entry-blocks {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 640px) {
    .entry-blocks {
      grid-template-columns: 1fr;
    }
  }

  .entry-block {
    padding: 12px 14px;
    border-radius: var(--border-radius);
    background-color: var(--surface);
    border: 1px solid var(--border-color);
  }

  .entry-block--canon {
    border-left: 3px solid var(--cyan);
  }

  .entry-block--theory {
    border-left: 3px solid var(--violet);
  }

  .block-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 4px;
  }

  .entry-block--canon .block-label {
    color: var(--cyan);
  }

  .entry-block--theory .block-label {
    color: var(--violet-light);
  }

  .entry-block p {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
</style>
