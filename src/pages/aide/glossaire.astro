---
import ListingLayout from '../../layouts/ListingLayout.astro';
import Icon from '../../components/Icon.astro';

const terms = [
  {
    term: 'Siècle oublié',
    abbr: 'Période « effacée » de l’histoire du monde',
    def: 'Intervalle d’environ cent ans, il y a 800 ans, dont le Gouvernement Mondial interdit l’étude. La théorie propose de le lire non comme un passé perdu, mais comme l’écho projeté du présent.',
  },
  {
    term: 'Ponéglyphes',
    abbr: 'Stèles de pierre indéléstructibles',
    def: 'Blocs gravés en écriture antique dispersés à travers le monde. Dans la théorie, ils ne raconteraient pas le passé : ils enregistreraient le présent… avant qu’il n’arrive.',
  },
  {
    term: 'Joy Boy',
    abbr: 'Figure légendaire du Siècle oublié',
    def: 'Auteur de la lettre d’excuse à Poséidon et détenteur d’une promesse brisée. Article canonique : « Joy Boy », pilier Figures et identités.',
    href: '/la-theorie/figures-et-identites/joy-boy',
  },
  {
    term: 'Voix de toutes choses',
    abbr: 'Capacité mystérieuse d’écoute',
    def: 'Phénomène ressenti par quelques personnages (Roger, Luffy, Momonosuke…). La théorie l’envisage comme un canal possible entre les époques.',
  },
];
---

<ListingLayout
  title="Glossaire"
  description="Les termes clés de la théorie : Siècle oublié, Ponéglyphes, Joy Boy, Voix de toutes choses…"
  breadcrumbs={[
    { label: 'Accueil', href: '/' },
    { label: 'Aide' },
    { label: 'Glossaire' },
  ]}
>
  <header class="mt-5">
    <p class="cat-chip">Aide</p>
    <h1 class="mt-3 font-display text-3xl font-bold text-ink sm:text-4xl">Glossaire</h1>
    <p class="lede max-w-2xl">
      Les termes qui reviennent sans cesse dans la théorie, définis une fois —
      et réutilisés partout.
    </p>
    <p class="mt-4"><span class="demo-note"><Icon name="sparkles" class="size-3.5" />Maquette d’interface — définitions d’exemple</span></p>
  </header>

  <dl class="mt-10 space-y-4">
    {terms.map((item) => (
      <div class="rounded-2xl border border-line bg-depth/60 p-5">
        <dt class="flex flex-wrap items-baseline gap-x-3">
          <span class="font-display text-lg font-bold text-ink">{item.term}</span>
          <span class="text-xs uppercase tracking-[0.14em] text-mist/55">{item.abbr}</span>
        </dt>
        <dd class="mt-2 text-sm leading-relaxed text-mist/80">
          {item.def}
          {item.href && (
            <a href={item.href} class="ml-1.5 inline-flex items-center gap-1 text-cyan hover:underline">
              Lire l’article <Icon name="arrow-right" class="size-3.5" />
            </a>
          )}
        </dd>
      </div>
    ))}
  </dl>
</ListingLayout>
