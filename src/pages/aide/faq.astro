---
import ListingLayout from '../../layouts/ListingLayout.astro';
import Icon from '../../components/Icon.astro';

const questions = [
  {
    q: 'Comment éviter les spoilers des derniers chapitres ?',
    a: 'Ouvrez le réglage anti-spoilers (icône bouclier dans la barre de navigation) et indiquez le dernier chapitre que vous avez lu. Les contenus liés à des chapitres plus récents seront floutés, mais révélables d’un clic. C’est une aide de navigation, pas une protection absolue.',
  },
  {
    q: 'Comment fonctionne la recherche ?',
    a: 'Appuyez sur Ctrl/⌘ + K (ou sur « / ») et tapez votre requête. La recherche est propulsée par Pagefind : un index statique est généré à chaque build, sans serveur ni base de données.',
  },
  {
    q: 'Fait, interprétation, hypothèse : quelle différence ?',
    a: 'Chaque affirmation est marquée par un encadré coloré : cyan pour un fait du manga rattaché à un chapitre, violet pour une interprétation recoupée, doré pointillé pour une hypothèse falsifiable suivie dans le tableau des prédictions.',
  },
  {
    q: 'Puis-je proposer une correction ou une objection ?',
    a: 'Oui : le projet est ouvert. Ouvrez une Issue pour discuter d’un point de la théorie ou signaler une erreur, ou une Pull Request pour proposer directement une modification.',
  },
];
---

<ListingLayout
  title="FAQ"
  description="Questions fréquentes : anti-spoilers, recherche, niveaux de certitude, contribution."
  breadcrumbs={[
    { label: 'Accueil', href: '/' },
    { label: 'Aide' },
    { label: 'FAQ' },
  ]}
>
  <header class="mt-5">
    <p class="cat-chip">Aide</p>
    <h1 class="mt-3 font-display text-3xl font-bold text-ink sm:text-4xl">Foire aux questions</h1>
    <p class="lede max-w-2xl">
      L’essentiel pour lire la théorie dans de bonnes conditions — et y contribuer.
    </p>
    <p class="mt-4"><span class="demo-note"><Icon name="sparkles" class="size-3.5" />Maquette d’interface — réponses d’exemple</span></p>
  </header>

  <div class="mt-10 space-y-3">
    {questions.map((item, index) => (
      <details class="group rounded-xl border border-line bg-depth/60 transition open:border-cyan/30 open:bg-surface/30" open={index === 0}>
        <summary class="flex cursor-pointer list-none items-center justify-between gap-3 p-4 text-sm font-semibold text-ink [&::-webkit-details-marker]:hidden">
          {item.q}
          <Icon name="chevron-down" class="size-4 shrink-0 text-mist/50 transition-transform group-open:rotate-180" />
        </summary>
        <p class="border-t border-line px-4 py-3.5 text-sm leading-relaxed text-mist/80">{item.a}</p>
      </details>
    ))}
  </div>
</ListingLayout>
