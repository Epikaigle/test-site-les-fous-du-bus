---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const publishedArticles = articles.filter(a => a.data.status === 'published');

// Recommended 16-step reading order
const orderedSteps = [
  { step: 1, title: 'Présentation de la théorie', href: '/theorie/siecle-oublie-present', summary: 'Le cadre général : pourquoi le Siècle Oublié ne s\'est pas produit dans le passé mais s\'écrit au présent.' },
  { step: 2, title: 'Blue Star, Grand Line et Red Line', href: '/theorie/fondations', summary: 'Les fondations géographiques de la planète et le découpage du monde.' },
  { step: 3, title: 'Lodestar', href: '/theorie/laugh-tale', summary: 'L\'île ultime de la navigation conventionnelle sur Grand Line.' },
  { step: 4, title: 'Laugh Tale', href: '/theorie/laugh-tale', summary: 'La destination finale, le secret du trésor et l\'énigme temporelle.' },
  { step: 5, title: 'One Piece', href: '/theorie/one-piece-histoire', summary: 'La nature du trésor laissé par Joy Boy et la promesse de Gol D. Roger.' },
  { step: 6, title: 'Siècle Oublié', href: '/theorie/siecle-oublie-present', summary: 'La période effacée de l\'histoire et la boucle de transmission.' },
  { step: 7, title: 'Royaume antique', href: '/theorie/theorie-complete', summary: 'La grande guerre originelle et la véritable civilisation des pionniers.' },
  { step: 8, title: 'Ponéglyphes', href: '/theorie/ponelyphes-futur', summary: 'Les stèles indestructibles gravées pour transmettre le futur aux époques antérieures.' },
  { step: 9, title: 'Joy Boy', href: '/theorie/joy-boy', summary: 'La figure légendaire, sa promesse au Royaume Ryūgū et la résonance du héros.' },
  { step: 10, title: 'Nika', href: '/theorie/nika', summary: 'Le Dieu du Soleil, le Guerrier de la Libération et le culte transmis à travers les époques.' },
  { step: 11, title: 'Monkey D. Luffy', href: '/theorie/luffy', summary: 'Le capitaine au Chapeau de Paille comme créateur originel de l\'histoire.' },
  { step: 12, title: 'Armes antiques', href: '/theorie/poseidon', summary: 'Poséidon, Pluton et Uranus : les trois forces majeures qui remodèleront le monde.' },
  { step: 13, title: 'Figures et identités', href: '/theorie/davy-jones', summary: 'Les miroirs et correspondances (Davy Jones, Teach, Ryuma, Zoro, Vivi, Lili).' },
  { step: 14, title: 'Peuples et témoins', href: '/theorie/elbaf-halley', summary: 'Les Géants d\'Elbaf, les Hommes-Poissons, les Shandias et les gardiens de la mémoire.' },
  { step: 15, title: 'Imu et le Gouvernement mondial', href: '/theorie/imu-nerona', summary: 'L\'autorité du Trône Vacant et la résistance face à l\'inévitable libération.' },
  { step: 16, title: 'Déluge et guerre finale', href: '/theorie/deluge-all-blue', summary: 'Le cataclysme final, la destruction de Red Line et l\'avènement d\'All Blue.' },
];

const recentUpdates = publishedArticles
  .sort((a, b) => (b.data.lastUpdatedChapter || 0) - (a.data.lastUpdatedChapter || 0))
  .slice(0, 6);
---

<WikiLayout title="La théorie" currentPath="/theorie">
  <div class="hero">
    <div class="text-violet font-semibold tracking-widest uppercase text-sm mb-3">Guide de lecture</div>
    <h1>La théorie</h1>
    <p class="subtitle">
      Suivez l'ordre chronologique et logique ci-dessous (de 1 à 16) pour appréhender le raisonnement et la démonstration globale étape par étape.
    </p>
  </div>

  <h2 class="section-title">Ordre de lecture recommandé (16 étapes)</h2>
  <div class="article-list">
    {orderedSteps.map((step) => (
      <a href={step.href} class="article-row">
        <span class="article-num">{step.step}</span>
        <div class="article-info">
          <span class="article-title">{step.title}</span>
          <span class="article-summary">{step.summary}</span>
        </div>
      </a>
    ))}
  </div>

  <h2 class="section-title">Mises à jour récentes</h2>
  <div class="article-list">
    {recentUpdates.map((article) => (
      <a href={`/theorie/${article.id}`} class="article-row">
        <div class="article-info">
          <span class="article-title">{article.data.title}</span>
          <span class="article-chapter">Mis à jour au chapitre {article.data.lastUpdatedChapter || '?'}</span>
        </div>
      </a>
    ))}
  </div>

  <Footer />
</WikiLayout>

<style>
  .hero {
    margin-bottom: 40px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .section-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
    margin-top: 44px;
  }

  .section-title:first-of-type {
    margin-top: 0;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
  }

  .article-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 15px 18px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease;
  }

  .article-row:hover {
    border-color: var(--violet);
    background-color: var(--surface);
    transform: translateY(-2px);
  }

  .article-num {
    font-size: 15px;
    font-weight: 700;
    color: var(--cyan);
    min-width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--cyan) 10%, transparent);
    border-radius: 50%;
    margin-top: 2px;
  }

  .article-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .article-title {
    font-size: 15.5px;
    font-weight: 600;
    color: var(--text-main);
    transition: color 0.15s;
  }

  .article-row:hover .article-title {
    color: var(--cyan);
  }

  .article-summary {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .article-chapter {
    font-size: 12.5px;
    color: var(--text-secondary);
  }
</style>
