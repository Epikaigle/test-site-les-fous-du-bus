---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const publishedArticles = articles.filter(a => a.data.status === 'published');
const mainArticles = publishedArticles
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 12);
---

<WikiLayout title="La théorie" currentPath="/theorie">
  <div class="hero">
    <div class="text-violet font-semibold tracking-widest uppercase text-sm mb-3">Sommaire</div>
    <h1>La théorie</h1>
    <p class="subtitle">
      Pour découvrir et lire l'argumentation principale dans son ensemble. Suivez l'ordre de lecture
      ci-dessous pour comprendre le raisonnement étape par étape.
    </p>
  </div>

  <h2 class="section-title">Articles principaux</h2>
  <div class="article-list">
    {mainArticles.map((article, i) => (
      <a href={`/theorie/${article.id}`} class="article-row">
        <span class="article-num">{i + 1}</span>
        <div class="article-info">
          <span class="article-title">{article.data.title}</span>
          <span class="article-summary">{article.data.summary}</span>
        </div>
      </a>
    ))}
  </div>

  <h2 class="section-title">Articles récents</h2>
  <div class="article-list">
    {publishedArticles
      .sort((a, b) => (b.data.lastUpdatedChapter || 0) - (a.data.lastUpdatedChapter || 0))
      .slice(0, 8)
      .map((article) => (
        <a href={`/theorie/${article.id}`} class="article-row">
          <span class="article-badge">{article.data.certainty === 'central' ? 'Central' : article.data.certainty === 'elevee' ? 'Élevée' : 'Moyenne'}</span>
          <div class="article-info">
            <span class="article-title">{article.data.title}</span>
            <span class="article-chapter">Mis à jour au chapitre {article.data.lastUpdatedChapter || '?'}</span>
          </div>
        </a>
      ))
    }
  </div>

  <div class="info-box">
    <h3>📖 Ordre de lecture recommandé</h3>
    <p>
      1. Le Siècle oublié est le présent → 2. Laugh Tale et Lodestar → 3. Joy Boy est Luffy →
      4. Nika est Luffy → 5. Les Ponéglyphes racontent le futur → 6. Poséidon est Shirahoshi →
      7. Davy Jones est Teach → 8. Vivi est Lili → 9. Emeth vient du futur → 10. Imu Nerona →
      11. Le Déluge et All Blue → 12. Les Dieux de One Piece
    </p>
  </div>

  <Footer />
</WikiLayout>

<style>
  .hero {
    margin-bottom: 48px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .section-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
    margin-top: 48px;
  }

  .section-title:first-of-type {
    margin-top: 0;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
  }

  .article-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 15px 18px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .article-row:hover {
    border-color: var(--violet);
    background-color: var(--surface);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--bg-main) 40%, transparent);
  }

  .article-num {
    font-size: 16px;
    font-weight: 700;
    color: var(--violet);
    min-width: 24px;
    text-align: center;
    padding-top: 2px;
  }

  .article-badge {
    font-size: 11.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 3px 9px;
    border-radius: 6px;
    background-color: color-mix(in srgb, var(--cyan) 10%, transparent);
    color: var(--cyan);
    border: 1px solid color-mix(in srgb, var(--cyan) 20%, transparent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .article-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .article-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
    transition: color 0.15s;
  }

  .article-row:hover .article-title {
    color: var(--cyan);
  }

  .article-summary {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .article-chapter {
    font-size: 12.5px;
    color: var(--text-secondary);
  }

  .info-box {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-left: 3px solid var(--violet);
    padding: 20px 24px;
    border-radius: var(--border-radius-lg);
    margin-top: 48px;
  }

  .info-box h3 {
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .info-box p {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 32px;
    }
  }
</style>
