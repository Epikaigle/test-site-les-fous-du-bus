---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { editorialStatusToFrench } from '@utils/format';

const articles = await getCollection('articles');
const publishedArticles = articles.filter(a => a.data.status === 'published');
const mainArticles = publishedArticles
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 12);
---

<WikiLayout title="La théorie" currentPath="/theorie">
  <div class="hero">
    <div class="text-violet font-semibold tracking-widest uppercase text-sm mb-3">Sommaire</div>
    <h1>La théorie</h1>
    <p class="subtitle">
      Pour découvrir et lire l'argumentation principale dans son ensemble. Suivez l'ordre de lecture
      recommandé ci-dessous pour appréhender les fondations et le raisonnement étape par étape.
    </p>
  </div>

  <h2 class="section-title">Articles principaux</h2>
  <div class="article-list">
    {mainArticles.map((article, i) => (
      <a href={`/theorie/${article.id}`} class="article-row">
        <span class="article-num">{i + 1}</span>
        <div class="article-info">
          <span class="article-title">{article.data.title}</span>
          <span class="article-summary">{article.data.summary}</span>
        </div>
      </a>
    ))}
  </div>

  <h2 class="section-title">Articles récents</h2>
  <div class="article-list">
    {publishedArticles
      .sort((a, b) => (b.data.lastUpdatedChapter || 0) - (a.data.lastUpdatedChapter || 0))
      .slice(0, 8)
      .map((article) => (
        <a href={`/theorie/${article.id}`} class="article-row">
          <div class="article-info">
            <span class="article-title">{article.data.title}</span>
            <span class="article-chapter">Mis à jour au chapitre {article.data.lastUpdatedChapter || '?'}</span>
          </div>
        </a>
      ))
    }
  </div>

  <div class="info-box">
    <h3>📖 Ordre de lecture recommandé</h3>
    <ol class="order-list">
      <li><strong>1. Blue Star, Grand Line & Red Line</strong> — Les fondations géographiques et le cadre du monde.</li>
      <li><strong>2. Lodestar & Laugh Tale</strong> — La destination finale et la vraie nature de la dernière île.</li>
      <li><strong>3. Le One Piece</strong> — Le trésor laissé par Joy Boy et la promesse de Gol D. Roger.</li>
      <li><strong>4. Siècle oublié & Ancien Royaume</strong> — La véritable chronologie et la grande guerre.</li>
      <li><strong>5. Les Ponéglyphes</strong> — Le message gravé dans la pierre et la transmission à travers les époques.</li>
      <li><strong>6. Joy Boy, Nika & Monkey D. Luffy</strong> — Les acteurs centraux et l'héritage du Guerrier de la Libération.</li>
      <li><strong>7. Armes antiques & Identités</strong> — Poséidon, Pluton, Uranus, et les figures clés.</li>
      <li><strong>8. Imu & Gouvernement mondial</strong> — L'autorité du trône vacant et les enjeux de la Guerre Finale.</li>
    </ol>
  </div>

  <Footer />
</WikiLayout>

<style>
  .hero {
    margin-bottom: 48px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .section-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
    margin-top: 48px;
  }

  .section-title:first-of-type {
    margin-top: 0;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
  }

  .article-row {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 15px 18px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: border-color 0.2s ease, background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .article-row:hover {
    border-color: var(--violet);
    background-color: var(--surface);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px color-mix(in srgb, var(--bg-main) 40%, transparent);
  }

  .article-num {
    font-size: 16px;
    font-weight: 700;
    color: var(--violet);
    min-width: 24px;
    text-align: center;
    padding-top: 2px;
  }

  .article-badge {
    font-size: 11.5px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 6px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .meta-badge--cyan {
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    color: var(--cyan);
    border: 1px solid color-mix(in srgb, var(--cyan) 28%, transparent);
  }

  .meta-badge--gold {
    background: color-mix(in srgb, var(--accent-gold) 12%, transparent);
    color: var(--accent-gold);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 28%, transparent);
  }

  .meta-badge--violet {
    background: color-mix(in srgb, var(--violet) 14%, transparent);
    color: var(--violet-light);
    border: 1px solid color-mix(in srgb, var(--violet) 30%, transparent);
  }

  .meta-badge--muted {
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }

  .article-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .article-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
    transition: color 0.15s;
  }

  .article-row:hover .article-title {
    color: var(--cyan);
  }

  .article-summary {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .article-chapter {
    font-size: 12.5px;
    color: var(--text-secondary);
  }

  .info-box {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-left: 3px solid var(--violet);
    padding: 20px 24px;
    border-radius: var(--border-radius-lg);
    margin-top: 48px;
  }

  .info-box h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 14px;
  }

  .order-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0;
    margin: 0;
    list-style: none;
    font-size: 14px;
    color: var(--text-secondary);
  }

  .order-list li strong {
    color: var(--text-main);
  }

  @media (max-width: 640px) {
    .hero {
      margin-bottom: 32px;
    }
  }
</style>
