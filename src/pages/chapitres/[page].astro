---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';

export async function getStaticPaths() {
  return [
    {
      params: { page: 'derniere-analyse' },
      props: {
        title: 'Dernière analyse',
        icon: '📖',
        desc: "L'analyse du chapitre le plus récent et son apport à la théorie.",
      },
    },
    {
      params: { page: 'toutes-les-analyses' },
      props: {
        title: 'Toutes les analyses',
        icon: '📚',
        desc: 'Liste complète des analyses chapitre par chapitre.',
      },
    },
    {
      params: { page: 'predictions' },
      props: {
        title: 'Prédictions',
        icon: '🔮',
        desc: 'Prédictions formulées par la théorie et leur statut actuel.',
      },
    },
    {
      params: { page: 'modifications' },
      props: {
        title: 'Modifications',
        icon: '📋',
        desc: 'Modifications apportées aux articles suite aux nouveaux chapitres.',
      },
    },
  ];
}

const { title, icon, desc } = Astro.props;
---

<WikiLayout title={title} currentPath={`/chapitres/${Astro.params.page}`}>
  <div class="placeholder-page">
    <span class="placeholder-icon">{icon}</span>
    <h1>{title}</h1>
    <p class="placeholder-desc">{desc}</p>

    <div class="placeholder-box">
      <h3>📊 En construction</h3>
      <p>
        Cette section sera alimentée au fur et à mesure de l'avancement de la théorie et de la
        publication des nouveaux chapitres.
      </p>
    </div>

    <div class="placeholder-links">
      <a href="/chapitres" class="placeholder-link">← Retour à Chapitres</a>
      <a href="/theorie" class="placeholder-link">📖 La théorie</a>
    </div>
  </div>
  <Footer />
</WikiLayout>

<style>
  .placeholder-page {
    text-align: center;
    padding: 48px 0;
  }
  .placeholder-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 16px;
  }
  .placeholder-page h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    margin-bottom: 12px;
  }
  .placeholder-desc {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .placeholder-box {
    background: var(--gradient-card);
    border: 1px solid var(--border-color);
    padding: 32px;
    border-radius: var(--border-radius-xl);
    max-width: 500px;
    margin: 0 auto 32px;
  }
  .placeholder-box h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .placeholder-box p {
    font-size: 14.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .placeholder-links {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .placeholder-link {
    display: inline-block;
    padding: 10px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.2s;
  }
  .placeholder-link {
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .placeholder-link:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px color-mix(in srgb, var(--bg-main) 45%, transparent);
  }
</style>
