---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { effectLabel } from '@utils/labels';

const chapters = await getCollection('chapters');
const sortedChapters = chapters.sort((a, b) => b.data.chapter - a.data.chapter);
---

<WikiLayout title="Chapitres" currentPath="/chapitres">
  <div class="page-header">
    <div class="text-accentGold font-semibold tracking-widest uppercase text-sm mb-3">Suivi</div>
    <h1>Chapitres</h1>
    <p class="page-desc">
      Suivez l'évolution de la théorie au fil des chapitres de <em>One Piece</em>. Chaque analyse apporte de nouvelles pistes, des éclaircissements et des correspondances avec le récit.
    </p>
  </div>

  <div class="nav-cards">
    <a href="/chapitres/derniere-analyse" class="nav-card">
      <span class="nav-card__icon">📖</span>
      <div>
        <h3>Dernière analyse</h3>
        <p>L'analyse du chapitre le plus récent et son apport à la théorie.</p>
      </div>
    </a>

    <a href="/chapitres/toutes-les-analyses" class="nav-card">
      <span class="nav-card__icon">📚</span>
      <div>
        <h3>Toutes les analyses</h3>
        <p>Liste complète des analyses chapitre par chapitre.</p>
      </div>
    </a>

    <a href="/chapitres/predictions" class="nav-card">
      <span class="nav-card__icon">🔮</span>
      <div>
        <h3>Prédictions</h3>
        <p>Prédictions formulées par la théorie et leur accompagnement.</p>
      </div>
    </a>

    <a href="/chapitres/modifications" class="nav-card">
      <span class="nav-card__icon">📋</span>
      <div>
        <h3>Modifications</h3>
        <p>Modifications apportées aux articles suite aux nouveaux chapitres.</p>
      </div>
    </a>
  </div>

  <h2 class="section-title">Derniers chapitres analysés</h2>
  <div class="chapter-list">
    {
      sortedChapters.map((ch) => (
        <a href={`/chapitres/${ch.data.chapter}`} class="chapter-item">
          <div class="chapter-item__badges">
            <span class="badge-chapter">Chap {ch.data.chapter}</span>
            <span class="badge-effect" class:list={[
              { 'badge-effect--violet': ch.data.effect === 'nouvelle-piste' },
              { 'badge-effect--gold': ch.data.effect === 'renforcement' || ch.data.effect === 'modification' },
            ]}>{effectLabel(ch.data.effect)}</span>
          </div>
          <h4>{ch.data.title}</h4>
          {ch.data.summary && <p class="chapter-item__desc">{ch.data.summary}</p>}
        </a>
      ))
    }
  </div>

  <Footer />
</WikiLayout>

<style>
  .page-header {
    margin-bottom: 48px;
  }

  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .page-desc {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .nav-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 12px;
    margin-bottom: 48px;
  }

  .nav-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px;
    background: var(--gradient-card);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .nav-card:hover {
    border-color: var(--violet);
    transform: translateY(-3px);
    box-shadow: 0 10px 28px color-mix(in srgb, var(--bg-main) 40%, transparent);
  }

  .nav-card__icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    margin-top: 2px;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--accent-gold) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 20%, transparent);
  }

  .nav-card h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 4px;
  }

  .nav-card p {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .section-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
  }

  .chapter-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 48px;
  }

  .chapter-item {
    display: block;
    padding: 18px 20px;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .chapter-item:hover {
    border-color: var(--cyan);
    transform: translateY(-2px);
  }

  .chapter-item__badges {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }

  .badge-chapter {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent-gold);
    background: color-mix(in srgb, var(--accent-gold) 10%, transparent);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .badge-effect {
    font-size: 11.5px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .badge-effect--violet {
    background: color-mix(in srgb, var(--violet) 14%, transparent);
    color: var(--violet-light);
  }

  .badge-effect--gold {
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    color: var(--cyan);
  }

  .chapter-item h4 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 6px;
  }

  .chapter-item__desc {
    font-size: 13.5px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }
</style>
