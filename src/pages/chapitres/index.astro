---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';
import { effectLabel } from '@utils/labels';

const chapters = await getCollection('chapters');
const sortedChapters = chapters.sort((a, b) => b.data.chapter - a.data.chapter);
---

<WikiLayout title="Chapitres" currentPath="/chapitres">
  <div class="page-header">
    <div class="text-accentGold font-semibold tracking-widest uppercase text-sm mb-3">Suivi</div>
    <h1>Chapitres</h1>
    <p class="page-desc">
      Suivez l'évolution de la théorie avec le manga. Chaque nouveau chapitre peut renforcer,
      modifier ou contredire les hypothèses existantes.
    </p>
  </div>

  <div class="nav-cards">
    <a href="/chapitres/derniere-analyse" class="nav-card">
      <span class="nav-card__icon">📖</span>
      <div>
        <h3>Dernière analyse</h3>
        <p>L'analyse du chapitre le plus récent et son apport à la théorie.</p>
      </div>
    </a>

    <a href="/chapitres/toutes-les-analyses" class="nav-card">
      <span class="nav-card__icon">📚</span>
      <div>
        <h3>Toutes les analyses</h3>
        <p>Liste complète des analyses chapitre par chapitre.</p>
      </div>
    </a>

    <a href="/chapitres/predictions" class="nav-card">
      <span class="nav-card__icon">🔮</span>
      <div>
        <h3>Prédictions</h3>
        <p>Prédictions formulées par la théorie et leur statut actuel.</p>
      </div>
    </a>

    <a href="/chapitres/modifications" class="nav-card">
      <span class="nav-card__icon">📋</span>
      <div>
        <h3>Modifications</h3>
        <p>Modifications apportées aux articles suite aux nouveaux chapitres.</p>
      </div>
    </a>

    <a href="/chapitres/contradictions" class="nav-card">
      <span class="nav-card__icon">❌</span>
      <div>
        <h3>Contradictions</h3>
        <p>Les éléments qui contredisent ou fragilisent la théorie.</p>
      </div>
    </a>

    <a href="/chapitres/hypotheses-abandonnees" class="nav-card">
      <span class="nav-card__icon">🗑️</span>
      <div>
        <h3>Hypothèses abandonnées</h3>
        <p>Les pistes qui ont été réfutées ou abandonnées en cours de route.</p>
      </div>
    </a>
  </div>

  <h2 class="section-title">Derniers chapitres analysés</h2>
  <div class="chapter-list">
    {
      sortedChapters.map((ch) => (
        <a href={`/chapitres/${ch.data.chapter}`} class="chapter-item">
          <div class="chapter-item__badges">
            <span class="badge-chapter">Chap {ch.data.chapter}</span>
            <span class="badge-effect" class:list={[
              { 'badge-effect--violet': ch.data.effect === 'nouvelle-piste' },
              { 'badge-effect--gold': ch.data.effect === 'renforcement' || ch.data.effect === 'modification' },
              { 'badge-effect--alert': ch.data.effect === 'contradiction' || ch.data.effect === 'refutation' },
            ]}>{effectLabel(ch.data.effect)}</span>
          </div>
          <h4>{ch.data.title}</h4>
          {ch.data.summary && <p class="chapter-item__desc">{ch.data.summary}</p>}
        </a>
      ))
    }
  </div>

  <div class="info-box">
    <h3>📊 Statistiques</h3>
    <div class="stats">
      <div class="stat">
        <span class="stat__value">{sortedChapters.length}</span>
        <span class="stat__label">Chapitres analysés</span>
      </div>
      <div class="stat">
        <span class="stat__value">{sortedChapters.filter((c) => c.data.effect === 'nouvelle-piste' || c.data.effect === 'renforcement').length}</span>
        <span class="stat__label">Apports positifs</span>
      </div>
      <div class="stat">
        <span class="stat__value">{sortedChapters.filter((c) => c.data.effect === 'contradiction' || c.data.effect === 'refutation').length}</span>
        <span class="stat__label">Contradictions</span>
      </div>
    </div>
  </div>

  <Footer />
</WikiLayout>

<style>
  .page-header {
    margin-bottom: 48px;
  }

  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .page-desc {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .nav-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px;
    margin-bottom: 48px;
  }

  .nav-card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 18px;
    background-color: var(--bg-main);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s;
  }

  .nav-card:hover {
    background-color: var(--bg-secondary);
    border-color: var(--violet);
  }

  .nav-card__icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .nav-card h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 4px;
    transition: color 0.2s;
  }

  .nav-card:hover h3 {
    color: var(--cyan);
  }

  .nav-card p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.4;
    margin: 0;
  }

  .section-title {
    font-size: 18px;
    font-weight: 600;
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-color);
  }

  .chapter-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 40px;
  }

  .chapter-item {
    display: block;
    padding: 16px 20px;
    background-color: var(--bg-main);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .chapter-item:hover {
    border-color: var(--violet);
    background-color: var(--bg-secondary);
  }

  .chapter-item__badges {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .badge-chapter {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 6px;
    border-radius: 3px;
    background-color: color-mix(in srgb, var(--cyan) 10%, transparent);
    color: var(--cyan);
    border: 1px solid color-mix(in srgb, var(--cyan) 20%, transparent);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge-effect {
    font-size: 11px;
    font-weight: 500;
    padding: 2px 6px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge-effect--violet {
    background-color: color-mix(in srgb, var(--violet) 10%, transparent);
    color: #d3b3ff;
    border: 1px solid color-mix(in srgb, var(--violet) 30%, transparent);
  }

  .badge-effect--gold {
    background-color: color-mix(in srgb, var(--accent-gold) 10%, transparent);
    color: var(--accent-gold);
    border: 1px solid color-mix(in srgb, var(--accent-gold) 20%, transparent);
  }

  .badge-effect--alert {
    background-color: color-mix(in srgb, var(--alert) 10%, transparent);
    color: var(--alert);
    border: 1px solid color-mix(in srgb, var(--alert) 30%, transparent);
  }

  .chapter-item h4 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 4px;
  }

  .chapter-item__desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .info-box {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    padding: 24px;
    border-radius: 4px;
    margin-top: 48px;
  }

  .info-box h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 16px;
  }

  .stats {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat__value {
    font-size: 28px;
    font-weight: 700;
    color: var(--cyan);
    line-height: 1;
  }

  .stat__label {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 4px;
  }
</style>
