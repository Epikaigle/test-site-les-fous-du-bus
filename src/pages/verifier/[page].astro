---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';

export async function getStaticPaths() {
  return [
    {
      params: { page: 'preuves' },
      props: {
        title: 'Preuves principales',
        icon: '🧩',
        desc: 'Les éléments probants tirés du manga qui soutiennent la théorie.',
      },
    },
    {
      params: { page: 'citations' },
      props: {
        title: 'Citations et scènes',
        icon: '💬',
        desc: 'Les dialogues et scènes clés du manga qui alimentent la théorie.',
      },
    },
    {
      params: { page: 'paralleles' },
      props: {
        title: 'Parallèles',
        icon: '🔍',
        desc: 'Comparaisons entre personnages, lieux et événements à travers les époques.',
      },
    },
    {
      params: { page: 'objections' },
      props: {
        title: 'Objections',
        icon: '⚠️',
        desc: 'Les arguments contre la théorie et les réponses apportées.',
      },
    },
    {
      params: { page: 'questions' },
      props: {
        title: 'Questions en suspens',
        icon: '❓',
        desc: 'Les éléments dont le fonctionnement exact n\'est pas encore complètement expliqué dans la version actuelle de la théorie.',
      },
    },
    {
      params: { page: 'sources' },
      props: {
        title: 'Sources & Références',
        icon: '📚',
        desc: "Méthodologie d'analyse, transcriptions et vidéos sources.",
      },
    },
  ];
}

const { title, icon, desc } = Astro.props;
const page = Astro.params.page;

// Sample tailored proofs with exact nuances
const detailedProofs = [
  {
    chapter: '967',
    title: 'La réaction de Roger sur Laugh Tale',
    quote: '« Joy Boy, j\'aurais aimé naître à la même époque que toi. »',
    established: 'Roger ne pouvait pas agir immédiatement et déclare être arrivé trop tôt.',
    theory: 'Le problème rencontré par Roger serait temporel : la dernière île s\'inscrit dans l\'époque où l\'histoire s\'accomplit au présent.',
    limit: 'La réplique ne prouve pas à elle seule que Laugh Tale se situe dans le futur ; elle peut refléter l\'absence de Poséidon à son époque.',
  },
  {
    chapter: '1122',
    title: 'La voix originelle de Joy Boy (Urara Takano)',
    quote: 'Émission du Haki suprême scellé dans le robot Emeth.',
    established: 'Dans l\'adaptation animée du chapitre 1122, la voix de Joy Boy est interprétée par Urara Takano.',
    theory: 'Oda utilise le premier doublage de Luffy (1998) pour créer une résonance sonore directe entre Luffy et la figure de Joy Boy.',
    limit: 'Il s\'agit d\'un choix de réalisation et de casting qui constitue un indice symbolique, non une preuve diégétique explicite.',
  },
  {
    chapter: '1043',
    title: 'La déclaration de Zunesha à Momonosuke',
    quote: '« Les tambours de la libération... Joy Boy est de retour ! »',
    established: 'L\'éveil du Fruit du Démon de Luffy réactive le rythme des tambours perçus par Zunesha.',
    theory: 'La signature de Joy Boy réside dans l\'état d\'esprit et le pouvoir d\'Éveil manifestés par Luffy.',
    limit: 'Zunesha peut reconnaître le Fruit du Démon ou la volonté héritée plutôt qu\'une réincarnation physique.',
  },
  {
    chapter: '968',
    title: 'La prophétie des deux souverains',
    quote: '« Notre souverain va bientôt naître... et un autre dans une mer lointaine. »',
    established: 'Les Rois des Mers prédisent la naissance simultanée de Shirahoshi et de l\'autre souverain.',
    theory: 'La prophétie annonce la convergence au présent des acteurs clés de la libération du monde.',
    limit: 'La prophétie s\'inscrit dans une ligne temporelle classique de prédiction du futur.',
  },
];

const detailedObjections = [
  {
    title: 'La rédaction et le rôle des Ponéglyphes',
    argument: 'Les Ponéglyphes sont présentés comme des stèles sculptées il y a 800 ans par le clan Kozuki.',
    response: 'Dans la théorie, les Ponéglyphes contiendraient les connaissances du futur. Une version étendue suggère que Momonosuke et Robin pourraient participer à leur transmission.',
  },
  {
    title: 'Le voyage temporel de Kozuki Toki',
    argument: 'Toki affirme être née il y a 800 ans et avoir voyagé dans le temps vers le futur grâce au Toki Toki no Mi.',
    response: 'La théorie examine si Toki est un témoin de la boucle ou si le pouvoir du Toki Toki no Mi permet la circulation des reliques.',
  },
  {
    title: 'L\'existence séculaire du Gouvernement Mondial',
    argument: 'Les Vingt Rois ont fondé le Gouvernement Mondial il y a 800 ans à la fin du Siècle Oublié.',
    response: 'La théorie propose que l\'autorité d\'Imu repose sur le maintien d\'un statu quo artificiel cherchant à figer le cours du temps.',
  },
];

const detailedQuestions = [
  {
    title: 'La recherche du Fruit de Nika depuis huit cents ans',
    argument: 'Le Gouvernement Mondial cherche le Hito Hito no Mi modèle Nika depuis 800 ans.',
    explanation: 'Point nécessitant une explication plus complète : l\'interaction exacte entre les recherches séculaires de la Marine et le déclenchement de l\'Éveil au présent.',
  },
  {
    title: 'L\'origine déclarée de Kozuki Toki',
    argument: 'Toki affirme venir d\'une époque située 800 ans dans le passé avant ses sauts temporels.',
    explanation: 'Point nécessitant une explication plus complète : l\'articulation précise entre ses origines et son rôle exact dans l\'acheminement des prophéties.',
  },
  {
    title: 'La présence physique d\'Emeth et de Zunesha',
    argument: 'Le robot géant Emeth et Zunesha portent les marques directes des événements survenus il y a 800 ans.',
    explanation: 'Point nécessitant une explication plus complète : les mécanismes assurant leur longévité et leur rôle exact au cours du Siècle Oublié.',
  },
];
---

<WikiLayout title={title} currentPath={`/verifier/${page}`}>
  <div class="verify-header">
    <span class="verify-icon">{icon}</span>
    <h1>{title}</h1>
    <p class="verify-desc">{desc}</p>
  </div>

  {page === 'preuves' && (
    <div class="verify-grid">
      {detailedProofs.map((item) => (
        <div class="proof-card">
          <div class="proof-header">
            <span class="proof-badge proof-badge--type">Fait & Interprétation</span>
            <span class="proof-chapter">Chapitre {item.chapter}</span>
          </div>
          <h3 class="proof-title">{item.title}</h3>
          {item.quote && (
            <blockquote class="proof-quote">
              {item.quote}
            </blockquote>
          )}
          <div class="proof-body">
            <div class="proof-section">
              <span class="proof-label proof-label--established">Ce que la scène établit :</span>
              <p>{item.established}</p>
            </div>
            <div class="proof-section">
              <span class="proof-label proof-label--theory">Lecture de la théorie :</span>
              <p>{item.theory}</p>
            </div>
            <div class="proof-section proof-section--limit">
              <span class="proof-label proof-label--limit">Limite / Nuance :</span>
              <p>{item.limit}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  {page === 'objections' && (
    <div class="verify-grid">
      {detailedObjections.map((obj) => (
        <div class="proof-card">
          <div class="proof-header">
            <span class="proof-badge proof-badge--alert">Objection majeure</span>
          </div>
          <h3 class="proof-title">{obj.title}</h3>
          <div class="proof-body">
            <div class="proof-section">
              <span class="proof-label">Argument adverse :</span>
              <p>{obj.argument}</p>
            </div>
            <div class="proof-section">
              <span class="proof-label proof-label--theory">Réponse de la théorie :</span>
              <p>{obj.response}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  {page === 'questions' && (
    <div class="verify-grid">
      {detailedQuestions.map((q) => (
        <div class="proof-card">
          <div class="proof-header">
            <span class="proof-badge proof-badge--type">Point à expliciter</span>
          </div>
          <h3 class="proof-title">{q.title}</h3>
          <div class="proof-body">
            <div class="proof-section">
              <span class="proof-label">Élément du récit :</span>
              <p>{q.argument}</p>
            </div>
            <div class="proof-section proof-section--limit">
              <span class="proof-label proof-label--limit">Point nécessitant une explication plus complète :</span>
              <p>{q.explanation}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  {page !== 'preuves' && page !== 'objections' && page !== 'questions' && (
    <div class="verify-box">
      <h3>📚 Dossier de vérification ({title})</h3>
      <p>
        Cette section répertorie la rigueur d'analyse du projet : faits du manga, interprétations narratives et questions ouvertes.
      </p>
    </div>
  )}

  <div class="verify-footer">
    <a href="/verifier" class="btn-back">← Retour à l'index Vérifier</a>
  </div>

  <Footer />
</WikiLayout>

<style>
  .verify-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .verify-icon {
    font-size: 2.8rem;
    display: block;
    margin-bottom: 12px;
  }
  .verify-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 10px;
  }
  .verify-desc {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .verify-grid {
    display: grid;
    gap: 20px;
    margin-bottom: 40px;
  }

  .proof-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: 24px;
  }

  .proof-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .proof-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .proof-badge--type {
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    color: var(--cyan);
    border: 1px solid color-mix(in srgb, var(--cyan) 25%, transparent);
  }

  .proof-badge--alert {
    background: color-mix(in srgb, var(--alert) 12%, transparent);
    color: var(--alert);
    border: 1px solid color-mix(in srgb, var(--alert) 25%, transparent);
  }

  .proof-chapter {
    font-size: 12.5px;
    color: var(--text-secondary);
    font-family: monospace;
  }

  .proof-title {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .proof-quote {
    font-style: italic;
    color: var(--text-main);
    border-left: 3px solid var(--violet);
    padding-left: 14px;
    margin: 0 0 16px 0;
    font-size: 14.5px;
    line-height: 1.6;
  }

  .proof-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .proof-section {
    background: var(--surface);
    padding: 10px 14px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
  }

  .proof-section--limit {
    border-left: 3px solid var(--accent-gold);
  }

  .proof-label {
    font-weight: 600;
    color: var(--text-main);
    font-size: 12.5px;
    display: block;
    margin-bottom: 2px;
  }

  .proof-label--established {
    color: var(--cyan);
  }

  .proof-label--theory {
    color: var(--violet-light);
  }

  .proof-label--limit {
    color: var(--accent-gold);
  }

  .verify-box {
    background: var(--surface);
    border: 1px solid var(--border-color);
    padding: 28px;
    border-radius: var(--border-radius-lg);
    margin-bottom: 40px;
  }

  .verify-box h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .verify-box p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .verify-footer {
    text-align: center;
    margin-bottom: 32px;
  }

  .btn-back {
    display: inline-block;
    padding: 10px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    color: var(--text-main);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    transform: translateY(-2px);
  }
</style>
