---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';

export async function getStaticPaths() {
  return [
    {
      params: { page: 'preuves' },
      props: {
        title: 'Preuves principales',
        icon: '🧩',
        desc: 'Les preuves les plus solides qui soutiennent le cœur de la théorie.',
      },
    },
    {
      params: { page: 'citations' },
      props: {
        title: 'Citations et scènes',
        icon: '💬',
        desc: 'Les dialogues et scènes clés du manga qui alimentent la théorie.',
      },
    },
    {
      params: { page: 'paralleles' },
      props: {
        title: 'Parallèles',
        icon: '🔍',
        desc: 'Comparaisons entre personnages, lieux et événements à travers les époques.',
      },
    },
    {
      params: { page: 'objections' },
      props: {
        title: 'Objections',
        icon: '⚠️',
        desc: 'Les arguments contre la théorie et les réponses apportées.',
      },
    },
    {
      params: { page: 'contradictions' },
      props: {
        title: 'Contradictions',
        icon: '❌',
        desc: 'Les éléments du manga qui contredisent ou fragilisent la théorie.',
      },
    },
    {
      params: { page: 'questions' },
      props: {
        title: 'Questions non résolues',
        icon: '❓',
        desc: 'Les points qui restent en suspens et nécessitent de nouveaux chapitres.',
      },
    },
    {
      params: { page: 'sources' },
      props: {
        title: 'Sources',
        icon: '📚',
        desc: "Méthodologie d'analyse et sources utilisées.",
      },
    },
  ];
}

const { title, icon, desc } = Astro.props;
---

<WikiLayout title={title} currentPath={`/verifier/${Astro.params.page}`}>
  <div class="placeholder-page">
    <span class="placeholder-icon">{icon}</span>
    <h1>{title}</h1>
    <p class="placeholder-desc">{desc}</p>

    <div class="placeholder-box">
      <h3>🔎 En construction</h3>
      <p>
        Cette section sera enrichie progressivement avec les preuves, citations et analyses tirées
        du manga.
      </p>
    </div>

    <div class="placeholder-links">
      <a href="/verifier" class="placeholder-link">← Retour à Vérifier</a>
      <a href="/theorie" class="placeholder-link">📖 La théorie</a>
    </div>
  </div>
  <Footer />
</WikiLayout>

<style>
  .placeholder-page {
    text-align: center;
    padding: 48px 0;
  }
  .placeholder-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 16px;
  }
  .placeholder-page h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    margin-bottom: 12px;
  }
  .placeholder-desc {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .placeholder-box {
    background: var(--gradient-card);
    border: 1px solid var(--border-color);
    padding: 32px;
    border-radius: var(--border-radius-xl);
    max-width: 500px;
    margin: 0 auto 32px;
  }
  .placeholder-box h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .placeholder-box p {
    font-size: 14.5px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .placeholder-links {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .placeholder-link {
    display: inline-block;
    padding: 10px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    color: var(--text-main);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.2s;
  }
  .placeholder-link {
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .placeholder-link:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    transform: translateY(-2px);
    box-shadow: 0 6px 18px color-mix(in srgb, var(--bg-main) 45%, transparent);
  }
</style>
