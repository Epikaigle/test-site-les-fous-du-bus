---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return [
    {
      params: { page: 'preuves' },
      props: {
        title: 'Preuves principales',
        icon: '🧩',
        desc: 'Les éléments probants tirés du manga qui soutiennent la théorie.',
      },
    },
    {
      params: { page: 'citations' },
      props: {
        title: 'Citations et scènes',
        icon: '💬',
        desc: 'Les dialogues et scènes clés du manga qui alimentent la théorie.',
      },
    },
    {
      params: { page: 'paralleles' },
      props: {
        title: 'Parallèles',
        icon: '🔍',
        desc: 'Comparaisons entre personnages, lieux et événements à travers les époques.',
      },
    },
    {
      params: { page: 'objections' },
      props: {
        title: 'Objections',
        icon: '⚠️',
        desc: 'Les arguments contre la théorie et les réponses apportées.',
      },
    },
    {
      params: { page: 'contradictions' },
      props: {
        title: 'Contradictions',
        icon: '❌',
        desc: 'Les éléments du manga qui contredisent ou fragilisent la théorie.',
      },
    },
    {
      params: { page: 'questions' },
      props: {
        title: 'Questions non résolues',
        icon: '❓',
        desc: 'Les points qui restent en suspens et nécessitent de nouveaux chapitres.',
      },
    },
    {
      params: { page: 'sources' },
      props: {
        title: 'Sources',
        icon: '📚',
        desc: "Méthodologie d'analyse et sources utilisées.",
      },
    },
  ];
}

const { title, icon, desc } = Astro.props;
const page = Astro.params.page;

// Fetch collection items according to page type
const evidenceItems = page === 'preuves' || page === 'citations' ? await getCollection('evidence') : [];
const objectionItems = page === 'objections' || page === 'contradictions' ? await getCollection('objections') : [];
---

<WikiLayout title={title} currentPath={`/verifier/${page}`}>
  <div class="verify-header">
    <span class="verify-icon">{icon}</span>
    <h1>{title}</h1>
    <p class="verify-desc">{desc}</p>
  </div>

  {page === 'preuves' && (
    <div class="verify-grid">
      {evidenceItems.map((item) => (
        <div class="proof-card">
          <div class="proof-header">
            <span class="proof-badge proof-badge--type">{item.data.type}</span>
            <span class="proof-chapter">Chapitre {item.data.chapter}</span>
          </div>
          <h3 class="proof-title">{item.data.title}</h3>
          {item.data.quote && (
            <blockquote class="proof-quote">
              « {item.data.quote} »
            </blockquote>
          )}
          <div class="proof-body">
            <div class="proof-label">Interprétation :</div>
            <p>Ce passage illustre la correspondance temporelle directe et la résonance du héros dans le récit.</p>
          </div>
        </div>
      ))}

      {evidenceItems.length === 0 && (
        <div class="proof-card">
          <div class="proof-header">
            <span class="proof-badge proof-badge--type">Dialogue</span>
            <span class="proof-chapter">Chapitre 967</span>
          </div>
          <h3 class="proof-title">La réaction de Roger sur Laugh Tale</h3>
          <blockquote class="proof-quote">
            « Joy Boy, j'aurais aimé naître à la même époque que toi. »
          </blockquote>
          <div class="proof-body">
            <div class="proof-label">Interprétation des Fous du Bus :</div>
            <p>Roger ne s'adresse pas nécessairement à un fantôme d'il y a 800 ans, mais au futur héros qui accomplira la promesse qu'il était venu trop tôt pour réaliser.</p>
            <div class="proof-counter">
              <span class="proof-label">Contre-argument :</span>
              <p>La lecture traditionnelle considère Joy Boy comme un roi de l'Ancien Royaume mort depuis des siècles.</p>
            </div>
          </div>
        </div>
      )}
    </div>
  )}

  {page === 'objections' && (
    <div class="verify-grid">
      {objectionItems.map((obj) => (
        <div class="proof-card">
          <div class="proof-header">
            <span class="proof-badge proof-badge--alert">{obj.data.strength}</span>
          </div>
          <h3 class="proof-title">{obj.data.title}</h3>
          <div class="proof-body">
            <div class="proof-label">Argument adverse :</div>
            <p>{obj.data.argument}</p>
            <div class="proof-counter">
              <span class="proof-label">Réponse de la théorie :</span>
              <p>{obj.data.response}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  {page !== 'preuves' && page !== 'objections' && (
    <div class="verify-box">
      <h3>📚 Dossier de vérification ({title})</h3>
      <p>
        Cette section répertorie la rigueur d'analyse du projet : distinction claire entre faits observés dans le manga, interprétations narratives et contre-hypothèses.
      </p>
    </div>
  )}

  <div class="verify-footer">
    <a href="/verifier" class="btn-back">← Retour à l'index Vérifier</a>
  </div>

  <Footer />
</WikiLayout>

<style>
  .verify-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .verify-icon {
    font-size: 2.8rem;
    display: block;
    margin-bottom: 12px;
  }
  .verify-header h1 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 700;
    margin-bottom: 10px;
  }
  .verify-desc {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .verify-grid {
    display: grid;
    gap: 20px;
    margin-bottom: 40px;
  }

  .proof-card {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    padding: 24px;
  }

  .proof-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .proof-badge {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 2px 8px;
    border-radius: 4px;
  }

  .proof-badge--type {
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
    color: var(--cyan);
    border: 1px solid color-mix(in srgb, var(--cyan) 25%, transparent);
  }

  .proof-badge--alert {
    background: color-mix(in srgb, var(--alert) 12%, transparent);
    color: var(--alert);
    border: 1px solid color-mix(in srgb, var(--alert) 25%, transparent);
  }

  .proof-chapter {
    font-size: 12.5px;
    color: var(--text-secondary);
    font-family: monospace;
  }

  .proof-title {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .proof-quote {
    font-style: italic;
    color: var(--text-main);
    border-left: 3px solid var(--violet);
    padding-left: 14px;
    margin: 0 0 16px 0;
    font-size: 14.5px;
    line-height: 1.6;
  }

  .proof-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .proof-label {
    font-weight: 600;
    color: var(--text-main);
    font-size: 13px;
    margin-bottom: 4px;
  }

  .proof-counter {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed var(--border-color);
  }

  .verify-box {
    background: var(--surface);
    border: 1px solid var(--border-color);
    padding: 28px;
    border-radius: var(--border-radius-lg);
    margin-bottom: 40px;
  }

  .verify-box h3 {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .verify-box p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .verify-footer {
    text-align: center;
    margin-bottom: 32px;
  }

  .btn-back {
    display: inline-block;
    padding: 10px 20px;
    background-color: var(--surface);
    border: 1px solid var(--border-color);
    border-radius: var(--border-radius-lg);
    color: var(--text-main);
    text-decoration: none;
    font-size: 14px;
    transition: all 0.2s ease;
  }

  .btn-back:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    transform: translateY(-2px);
  }
</style>
