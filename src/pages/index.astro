---
import WikiLayout from '@layouts/WikiLayout.astro';
import ChapterBanner from '@components/ChapterBanner.astro';
import CategoryCard from '@components/CategoryCard.astro';
import ArticleListItem from '@components/ArticleListItem.astro';
import Footer from '@components/Footer.astro';
---

<WikiLayout title="Accueil" currentPath="/">
  <div class="hero">
    <div class="hero-badge">
      <span class="hero-badge__dot"></span>
      <span>La théorie</span>
    </div>
    <h1 class="hero-title">
      Le Siècle oublié<br /><span class="text-gradient">est le présent</span>
    </h1>
    <svg
      class="wave-rule hero-wave"
      viewBox="0 0 240 12"
      preserveAspectRatio="none"
      aria-hidden="true"
    >
      <path
        d="M0 6 Q15 1 30 6 T60 6 T90 6 T120 6 T150 6 T180 6 T210 6 T240 6"
        fill="none"
        stroke="currentColor"
        stroke-width="1.2"
      />
    </svg>

    <div class="hero-text">
      <p>
        Le Siècle oublié, ce n'est pas une vieille histoire enterrée il y a 800 ans. C'est ce qui
        est en train de se passer maintenant, sous nos yeux, depuis le tout début de <em>One Piece</em>.
        La grande guerre, la chute du Gouvernement mondial, l'apparition de Joy Boy et la naissance
        d'un nouveau monde ne seraient pas des événements du passé : ce seraient ceux que Luffy et ses
        alliés sont en train de provoquer.
      </p>

      <p class="hero-text__more">
        Luffy, Vivi, Shirahoshi, Teach et les autres ne suivraient donc pas simplement les traces de
        personnages légendaires. Ce sont eux qui vont devenir ces légendes. Les Ponéglyphes ne
        raconteraient pas le passé, mais le futur gravé à l'avance puis envoyé 800 ans en arrière.
      </p>
    </div>

    <div class="hero-cta">
      <a href="/theorie/resume" class="btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
        Lire le résumé
      </a>
      <a href="/theorie/theorie-complete" class="btn-secondary">
        Théorie complète
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    </div>

    <div
      class="video-facade"
      id="video-facade"
      role="button"
      aria-label="Lire la vidéo de présentation"
      tabindex="0"
    >
      <img
        src="https://img.youtube.com/vi/SgJ25zjMJyo/maxresdefault.jpg"
        alt="Vidéo de présentation de la théorie"
        class="video-facade__img"
        loading="lazy"
      />
      <div class="video-facade__overlay">
        <div class="video-facade__play">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="white"
            xmlns="http://www.w3.org/2000/svg"
          >
            <polygon points="5,3 19,12 5,21"></polygon>
          </svg>
        </div>
        <span class="video-facade__label">Regarder la présentation</span>
      </div>
    </div>

    <script>
      const facade = document.getElementById('video-facade');
      const loadVideo = () => {
        if (facade && !facade.dataset.loaded) {
          facade.dataset.loaded = 'true';
          facade.innerHTML = `<iframe
            class="absolute top-0 left-0 w-full h-full"
            src="https://www.youtube.com/embed/SgJ25zjMJyo?si=pXYc71i2i7G5tG5h&autoplay=1"
            title="YouTube video player"
            style="border: none;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>`;
        }
      };
      facade?.addEventListener('click', loadVideo);
      facade?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          loadVideo();
        }
      });
    </script>
  </div>

  <ChapterBanner
    chapter="1188"
    title="Une communication à travers le temps"
    effect="Nouv. piste"
    href="/chapitres/1188"
  />

  <h2 class="section-title">
    <span class="section-title__accent"></span>
    Dossiers principaux
  </h2>
  <div class="grid">
    <CategoryCard
      icon="🌍"
      title="Monde et destinations"
      description="Blue Star, Grand Line, Laugh Tale, Lodestar : la géographie comme point de départ du raisonnement."
      href="/dossiers#monde-destinations"
    />
    <CategoryCard
      icon="📜"
      title="Histoire et temporalité"
      description="Siècle oublié, Ponéglyphes, voyage temporel et communication à travers les époques."
      href="/dossiers#histoire-temporalite"
    />
    <CategoryCard
      icon="🎭"
      title="Figures principales"
      description="Luffy, Joy Boy, Nika, Roger : les acteurs centraux de la théorie."
      href="/dossiers#figures-principales"
    />
    <CategoryCard
      icon="🔱"
      title="Armes antiques"
      description="Poséidon, Pluton, Uranus, Noah : leur véritable fonction et leur rôle dans la guerre finale."
      href="/dossiers#armes-antiques"
    />
    <CategoryCard
      icon="⚡"
      title="Technologies et pouvoirs"
      description="Vegapunk, Mother Flame, Fruits du Démon, Emeth et les connaissances perdues."
      href="/dossiers#technologies-pouvoirs"
    />
    <CategoryCard
      icon="⚖️"
      title="Gouvernement et guerre finale"
      description="Imu, Gorosei, Déluge, destruction de Red Line et création d'All Blue."
      href="/dossiers#gouvernement-mondial"
    />
  </div>

  <h2 class="section-title">
    <span class="section-title__accent"></span>
    Articles récents
  </h2>
  <div class="article-list">
    <ArticleListItem
      badge="Renforcement"
      badgeColor="gold"
      title="Le rôle du pont de Tequila Wolf"
      category="Monde, peuples"
      chapter="1188"
      href="/theorie/tequila-wolf"
    />
    <ArticleListItem
      badge="Nouv. piste"
      badgeColor="violet"
      title="La véritable signification du D."
      category="Figures et identités"
      chapter="1188"
      href="/theorie/signification-d"
    />
    <ArticleListItem
      badge="Modification"
      badgeColor="gold"
      title="L'énergie antique et la Flamme Mère"
      category="Science et énergie"
      chapter="1187"
      href="/theorie/energie-antique"
    />
    <ArticleListItem
      badge="Renforcement"
      badgeColor="gold"
      title="Luffy deviendra Joy Boy"
      category="Figures et identités"
      chapter="1186"
      href="/theorie/joy-boy"
    />
  </div>

  <Footer />
</WikiLayout>

<style>
  /* ===== HERO (contained block) ===== */
  .hero {
    position: relative;
    margin-bottom: 48px;
    padding: 40px 40px 36px;
    border-radius: var(--border-radius-xl);
    border: 1px solid var(--border-color);
    background:
      linear-gradient(
        150deg,
        color-mix(in srgb, var(--bg-secondary) 92%, transparent),
        color-mix(in srgb, var(--surface) 60%, transparent)
      );
    box-shadow: 0 20px 60px color-mix(in srgb, var(--bg-main) 45%, transparent);
    overflow: hidden;
  }

  /* Thin gradient line crowning the hero block */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: var(--gradient-hero);
    opacity: 0.55;
    z-index: 1;
    pointer-events: none;
  }

  .hero > * {
    position: relative;
    z-index: 1;
    /* Staggered entrance */
    animation: hero-rise 0.65s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero-badge { animation-delay: 0.05s; }
  .hero-title { animation-delay: 0.12s; }
  .hero-wave { animation-delay: 0.18s; }
  .hero-text { animation-delay: 0.24s; }
  .hero-cta { animation-delay: 0.3s; }
  .video-facade { animation-delay: 0.38s; }

  .hero-wave {
    max-width: 300px;
    margin: 6px 0 22px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12.5px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--violet-light);
    margin-bottom: 16px;
    padding: 7px 15px;
    border-radius: 100px;
    background: color-mix(in srgb, var(--violet) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--violet) 20%, transparent);
  }

  .hero-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--violet-light);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin-bottom: 20px;
    line-height: 1.15;
    letter-spacing: -0.03em;
  }

  .hero-text {
    font-size: 16px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.75;
  }

  .hero-text p + p {
    margin-top: 12px;
  }

  .hero-text__more {
    display: none;
  }

  @media (min-width: 768px) {
    .hero-text__more {
      display: block;
    }
  }

  /* ===== CTA BUTTONS ===== */
  .hero-cta {
    display: flex;
    gap: 12px;
    margin-top: 28px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    background: var(--gradient-border);
    color: white;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 2px 12px var(--glow-violet);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 26px var(--glow-violet);
  }

  .btn-primary:active {
    transform: translateY(0) scale(0.98);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 22px;
    background-color: transparent;
    color: var(--text-main);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .btn-secondary svg {
    transition: transform 0.25s ease;
  }

  .btn-secondary:hover {
    border-color: var(--cyan-dim);
    color: var(--cyan);
    box-shadow: 0 0 16px var(--glow-cyan);
  }

  .btn-secondary:hover svg {
    transform: translateX(3px);
  }

  .btn-secondary:active {
    transform: scale(0.98);
  }

  /* ===== VIDEO FACADE ===== */
  .video-facade {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-color);
    margin-top: 32px;
    cursor: pointer;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .video-facade:hover {
    border-color: color-mix(in srgb, var(--violet) 40%, var(--border-color));
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4), 0 0 20px var(--glow-violet);
  }

  .video-facade__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-facade__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(7, 2, 10, 0.7) 0%,
      rgba(7, 2, 10, 0.3) 50%,
      rgba(7, 2, 10, 0.1) 100%
    );
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    transition: background 0.3s ease;
  }

  .video-facade:hover .video-facade__overlay {
    background: linear-gradient(
      to top,
      rgba(7, 2, 10, 0.8) 0%,
      rgba(7, 2, 10, 0.4) 50%,
      rgba(7, 2, 10, 0.15) 100%
    );
  }

  .video-facade__play {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--violet);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px var(--glow-violet);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .video-facade:hover .video-facade__play {
    transform: scale(1.1);
    box-shadow: 0 6px 30px var(--glow-violet);
  }

  .video-facade__label {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
  }

  /* ===== SECTION TITLES ===== */
  .section-title {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
    margin-top: 56px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-title__accent {
    display: inline-block;
    width: 24px;
    height: 3px;
    border-radius: 2px;
    background: var(--gradient-border);
    flex-shrink: 0;
  }

  .section-title:first-of-type {
    margin-top: 0;
  }

  /* ===== GRID & LIST ===== */
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .hero {
      margin-bottom: 32px;
      padding: 28px 20px 24px;
    }
    .section-title {
      margin-top: 40px;
      font-size: 17.5px;
    }
    .video-facade__play {
      width: 52px;
      height: 52px;
    }
    .video-facade__play svg {
      width: 20px;
      height: 20px;
    }
  }
</style>
