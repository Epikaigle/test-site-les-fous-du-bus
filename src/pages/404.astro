---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout
  title="Page introuvable | Les Fous du Bus"
  description="Cette page n'existe pas ou a été déplacée."
>
  <section class="relative overflow-hidden">
    <svg viewBox="0 0 48 48" aria-hidden="true" class="puzzle-float absolute left-[12%] top-[30%] size-14 text-volt/30" style="--rot: -12deg; --dur: 10s;">
      <use href="#lf-piece" fill="currentColor" opacity="0.4"></use>
    </svg>
    <svg viewBox="0 0 48 48" aria-hidden="true" class="puzzle-float absolute right-[14%] top-[52%] size-20 text-magenta/25" style="--rot: 22deg; --dur: 12s; --delay: -3s;">
      <use href="#lf-piece" fill="currentColor" opacity="0.35"></use>
    </svg>

    <div class="relative mx-auto max-w-xl px-4 py-28 text-center sm:py-36">
      <p class="font-display text-7xl font-bold text-gradient sm:text-8xl">404</p>
      <h1 class="mt-4 font-display text-2xl font-bold text-ink sm:text-3xl">
        Cette page a été engloutie<br />par le Siècle oublié
      </h1>
      <p class="mx-auto mt-4 max-w-md text-sm leading-relaxed text-mist/75">
        Le contenu que vous cherchez n’existe pas (encore), ou son adresse a
        changé. Aucune URL publiée ne disparaît sans redirection — celle-ci doit
        être une période troublée de l’histoire.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class="btn-primary px-5 py-2.5 text-sm">
          <Icon name="arrow-left" class="size-4" />
          Retour à l’accueil
        </a>
        <button type="button" data-search-open class="btn-ghost px-5 py-2.5 text-sm">
          <Icon name="search" class="size-4" />
          Rechercher (⌘ K)
        </button>
      </div>
    </div>
  </section>
</BaseLayout>
