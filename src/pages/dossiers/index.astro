---

<WikiLayout title="Dossiers" currentPath="/dossiers">
  <div class="hero">
    <div class="text-violet font-semibold tracking-widest uppercase text-sm mb-3">Dossiers</div>
    <h1>Dossiers</h1>
    <p class="subtitle">
      Pour atteindre directement un sujet précis. Chaque dossier explore un thème de la théorie
      de manière autonome, avec ses preuves, ses objections et ses liens vers les autres articles.
    </p>
  </div>

  <div class="sections">
    {
      sections.map((section) => (
        <div class="section-block" id={section.id}>
          <div class="section-header">
            <span class="section-icon">{section.icon}</span>
            <div>
              <h2>{section.title}</h2>
              <p>{section.description}</p>
            </div>
          </div>
          <div class="section-links">
            {section.links.map((link) => (
              <a href={link.href} class="section-link">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>

  <Footer />
</WikiLayout>

<style>
  .hero {
    margin-bottom: 48px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .section-block {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 24px;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }

  .section-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .section-header h2 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .section-header p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .section-links {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .section-link {
    display: inline-block;
    padding: 5px 12px;
    font-size: 12px;
    border-radius: 4px;
    background-color: var(--surface);
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid var(--border-color);
    transition: all 0.15s;
  }

  .section-link:hover {
    border-color: var(--violet);
    color: var(--cyan);
    background-color: var(--bg-main);
  }

  @media (max-width: 640px) {
    .section-block {
      padding: 16px;
    }
    .section-header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
