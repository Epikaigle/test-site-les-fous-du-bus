---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const publishedArticles = articles.filter(a => a.data.status === 'published');

interface DossierSection {
  id: string;
  icon: string;
  title: string;
  description: string;
}

const sections: DossierSection[] = [
  {
    id: 'monde-destinations',
    icon: '🌍',
    title: 'Monde et destinations',
    description: 'La géographie du monde et les lieux qui fondent la théorie.',
  },
  {
    id: 'histoire-temporalite',
    icon: '📜',
    title: 'Histoire et temporalité',
    description: 'Le mécanisme temporel, les Ponéglyphes et la communication entre les époques.',
  },
  {
    id: 'figures-principales',
    icon: '🎭',
    title: 'Figures principales',
    description: 'Luffy, Joy Boy, Nika : les acteurs centraux de la théorie.',
  },
  {
    id: 'personnages-identites',
    icon: '👥',
    title: 'Personnages et identités',
    description: 'Les parallèles et les liens entre personnages anciens et modernes.',
  },
  {
    id: 'armes-antiques',
    icon: '🔱',
    title: 'Armes antiques',
    description: 'Poséidon, Pluton, Uranus et leur rôle dans la guerre finale.',
  },
  {
    id: 'technologies-pouvoirs',
    icon: '⚡',
    title: 'Technologies et pouvoirs',
    description: 'Vegapunk, Mother Flame, Fruits du Démon et les technologies perdues.',
  },
  {
    id: 'peuples-royaumes',
    icon: '🗺️',
    title: 'Peuples, royaumes et témoins',
    description: 'Les nations, les peuples et les témoins vivants de l\'histoire.',
  },
  {
    id: 'dieux-croyances',
    icon: '☀️',
    title: 'Dieux et croyances',
    description: 'Comment un être, un pouvoir ou une peur devient un dieu aux yeux des peuples.',
  },
  {
    id: 'transmission-memoire',
    icon: '🎵',
    title: 'Transmission et mémoire',
    description: 'Volonté héritée, promesses, chants et transmission à travers les époques.',
  },
  {
    id: 'gouvernement-mondial',
    icon: '🏛️',
    title: 'Gouvernement mondial',
    description: 'Imu, Gorosei, Dragons Célestes et la structure du pouvoir mondial.',
  },
  {
    id: 'guerre-finale',
    icon: '⚔️',
    title: 'Guerre finale',
    description: 'La Grande Guerre, le Déluge, la destruction de Red Line et la coalition finale.',
  },
];
---

<WikiLayout title="Dossiers" currentPath="/dossiers">
  <div class="hero">
    <div class="text-violet font-semibold tracking-widest uppercase text-sm mb-3">Dossiers</div>
    <h1>Dossiers</h1>
    <p class="subtitle">
      Pour atteindre directement un sujet précis. Chaque dossier explore un thème de la théorie
      de manière autonome, avec ses preuves, ses objections et ses liens vers les autres articles.
    </p>
  </div>

  <div class="sections">
    {sections.map((section) => {
      const sectionArticles = publishedArticles.filter(a => a.data.category === section.id);
      return (
        <div class="section-block" id={section.id}>
          <div class="section-header">
            <span class="section-icon">{section.icon}</span>
            <div>
              <h2>{section.title}</h2>
              <p>{section.description}</p>
              <p class="article-count">{sectionArticles.length} article{sectionArticles.length > 1 ? 's' : ''}</p>
            </div>
          </div>
          {sectionArticles.length > 0 ? (
            <div class="article-list">
              {sectionArticles.sort((a, b) => a.data.order - b.data.order).map((article) => (
                <a href={`/theorie/${article.id}`} class="article-link">
                  <span class="article-title">{article.data.title}</span>
                  {article.data.lastUpdatedChapter && (
                    <span class="article-chapter">Chap. {article.data.lastUpdatedChapter}</span>
                  )}
                </a>
              ))}
            </div>
          ) : (
            <p class="no-articles">Dossier en cours de rédaction</p>
          )}
        </div>
      );
    })}
  </div>

  <Footer />
</WikiLayout>

<style>
  .hero {
    margin-bottom: 48px;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: 15px;
    color: var(--text-secondary);
    max-width: 700px;
    line-height: 1.6;
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .section-block {
    background-color: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 6px;
    padding: 24px;
  }

  .section-header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }

  .section-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
  }

  .section-header h2 {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 4px;
  }

  .section-header p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .article-count {
    font-size: 11px !important;
    color: var(--violet) !important;
    margin-top: 4px !important;
  }

  .article-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .article-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 14px;
    background-color: var(--bg-main);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.15s;
  }

  .article-link:hover {
    border-color: var(--violet);
    background-color: var(--surface);
  }

  .article-title {
    font-size: 13px;
    color: var(--text-main);
    font-weight: 500;
  }

  .article-link:hover .article-title {
    color: var(--cyan);
  }

  .article-chapter {
    font-size: 11px;
    color: var(--text-secondary);
    background-color: var(--surface);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .no-articles {
    font-size: 13px;
    color: var(--text-secondary);
    font-style: italic;
    padding: 12px;
  }

  @media (max-width: 640px) {
    .section-block {
      padding: 16px;
    }
    .section-header {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>
