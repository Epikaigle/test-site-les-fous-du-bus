---
import WikiLayout from '@layouts/WikiLayout.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const published = articles.filter(a => a.data.status === 'published');

// 12 articles principaux dans l'ordre de lecture


// Build article map
const articleMap = new Map<string, typeof published[0]>();
for (const a of published) {
  articleMap.set(a.id, a);
}

// Certainty colors
---

<WikiLayout title="Carte mentale" currentPath="/explorer/carte-mentale">
  <div class="page-header">
    <div class="text-violet font-semibold tracking-widest uppercase text-sm mb-3">🧠 Visualisation</div>
    <h1>Carte mentale de la théorie</h1>
    <p class="page-desc">
      Vue d'ensemble interactive des 12 piliers de la théorie et de leurs connexions.
      Cliquez sur un nœud pour accéder à l'article complet.
    </p>
  </div>



  <!-- Mind map container -->
  <div class="mindmap-wrapper" id="mindmap-wrapper">
    <div class="mindmap-controls">
      <button id="zoom-in" class="control-btn" aria-label="Zoom avant">+</button>
      <button id="zoom-out" class="control-btn" aria-label="Zoom arrière">−</button>
      <button id="zoom-reset" class="control-btn" aria-label="Réinitialiser">⟲</button>
    </div>
    <svg
      id="mindmap-svg"
      viewBox="0 0 1400 900"
      class="mindmap-svg"
      preserveAspectRatio="xMidYMid meet"
    >
      <defs>
        <!-- Glow filter for center node -->
        <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="4" result="blur" />
          <feMerge>
            <feMergeNode in="blur" />
            <feMergeNode in="SourceGraphic" />
          </feMerge>
        </filter>
        <!-- Drop shadow -->
        <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
          <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="rgba(0,0,0,0.4)" />
        </filter>
      </defs>

      <!-- Connections will be drawn here by JS -->
      <g id="connections"></g>
      <!-- Nodes will be placed here by JS -->
      <g id="nodes"></g>
    </svg>
  </div>

  <!-- Article detail panel -->
  <div id="detail-panel" class="detail-panel hidden">
    <button id="detail-close" class="detail-close" aria-label="Fermer">✕</button>
    <div id="detail-content" class="detail-content"></div>
  </div>

  <!-- Textual Alternative for Accessibility & SEO -->
  <section class="mt-12 pt-8 border-t border-borderColor" aria-label="Version textuelle de la carte mentale">
    <h2 class="text-xl font-bold text-textMain mb-6">Version textuelle de la carte mentale</h2>
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mb-12">
      <div class="bg-bgSecondary border border-borderColor p-5 rounded-xl">
        <h3 class="font-bold text-cyan mb-3">⏳ Mécanisme temporel</h3>
        <ul class="space-y-2 text-sm text-textSecondary">
          <li>• <a href="/theorie/siecle-oublie-present" class="hover:text-cyan transition-colors">Le Siècle Oublié est le présent</a></li>
          <li>• <a href="/theorie/laugh-tale" class="hover:text-cyan transition-colors">Laugh Tale</a></li>
          <li>• <a href="/theorie/one-piece-histoire" class="hover:text-cyan transition-colors">One Piece</a></li>
          <li>• <a href="/theorie/ponelyphes-futur" class="hover:text-cyan transition-colors">Ponéglyphes</a></li>
        </ul>
      </div>

      <div class="bg-bgSecondary border border-borderColor p-5 rounded-xl">
        <h3 class="font-bold text-cyan mb-3">🎭 Identités</h3>
        <ul class="space-y-2 text-sm text-textSecondary">
          <li>• <a href="/theorie/joy-boy" class="hover:text-cyan transition-colors">Joy Boy & Monkey D. Luffy</a></li>
          <li>• <a href="/theorie/nika" class="hover:text-cyan transition-colors">Nika & Monkey D. Luffy</a></li>
          <li>• <a href="/theorie/davy-jones" class="hover:text-cyan transition-colors">Davy Jones & Marshall D. Teach</a></li>
          <li>• <a href="/theorie/vivi" class="hover:text-cyan transition-colors">Nefertari D. Lili & Vivi</a></li>
          <li>• <a href="/theorie/ryuma" class="hover:text-cyan transition-colors">Shimotsuki Ryuma & Zoro</a></li>
        </ul>
      </div>

      <div class="bg-bgSecondary border border-borderColor p-5 rounded-xl">
        <h3 class="font-bold text-cyan mb-3">🔱 Armes antiques</h3>
        <ul class="space-y-2 text-sm text-textSecondary">
          <li>• <a href="/theorie/poseidon" class="hover:text-cyan transition-colors">Poséidon & Shirahoshi</a></li>
          <li>• <a href="/theorie/pluton" class="hover:text-cyan transition-colors">Pluton & Water Seven</a></li>
          <li>• <a href="/theorie/uranus" class="hover:text-cyan transition-colors">Uranus</a></li>
        </ul>
      </div>

      <div class="bg-bgSecondary border border-borderColor p-5 rounded-xl">
        <h3 class="font-bold text-cyan mb-3">⚡ Technologie & transmission</h3>
        <ul class="space-y-2 text-sm text-textSecondary">
          <li>• <a href="/theorie/emeth-futur" class="hover:text-cyan transition-colors">Emeth</a></li>
          <li>• <a href="/theorie/energie-antique" class="hover:text-cyan transition-colors">Énergie antique</a></li>
          <li>• <a href="/theorie/binks-no-sake" class="hover:text-cyan transition-colors">Binks no Sake</a></li>
          <li>• <a href="/theorie/volonte-heritee" class="hover:text-cyan transition-colors">Volonté héritée</a></li>
        </ul>
      </div>

      <div class="bg-bgSecondary border border-borderColor p-5 rounded-xl">
        <h3 class="font-bold text-cyan mb-3">👑 Gouvernement & Antagonistes</h3>
        <ul class="space-y-2 text-sm text-textSecondary">
          <li>• <a href="/theorie/imu-nerona" class="hover:text-cyan transition-colors">Imu Nerona</a></li>
          <li>• <a href="/theorie/vingt-rois-chevaliers-divins" class="hover:text-cyan transition-colors">Les Vingt Rois</a></li>
          <li>• <a href="/theorie/deluge-all-blue" class="hover:text-cyan transition-colors">Le Déluge et All Blue</a></li>
        </ul>
      </div>
    </div>
  </section>

  <Footer />
</WikiLayout>

<script>
  // ─── Mind map data ───────────────────────────────────────────
  const CX = 700, CY = 450;

  const branches = [
    {
      id: 'temps',
      label: '⏳ Mécanisme\ntemporel',
      color: '#8091cf',
      angle: -90,
      dist: 240,
    },
    {
      id: 'identites',
      label: '🎭 Identités',
      color: '#5fb9c2',
      angle: -30,
      dist: 260,
    },
    {
      id: 'armes',
      label: '🔱 Armes\nantiques',
      color: '#e0ab4e',
      angle: 30,
      dist: 260,
    },
    {
      id: 'tech',
      label: '⚡ Technologie\n& transmission',
      color: '#d98b74',
      angle: 150,
      dist: 260,
    },
    {
      id: 'antagoniste',
      label: '🏛️ Antagoniste',
      color: '#c25b4f',
      angle: 210,
      dist: 240,
    },
    {
      id: 'fin',
      label: '⚔️ Guerre\nfinale',
      color: '#e0ab4e',
      angle: 90,
      dist: 240,
    },
  ];

  const articles = [
    // Center
    { slug: 'siecle-oublie-present', title: 'Le Siècle oublié\nest le présent', branch: 'center', certainty: 'central', order: 0 },

    // Temps
    { slug: 'laugh-tale', title: 'Laugh Tale =\nLodestar', branch: 'temps', certainty: 'central', order: 10 },
    { slug: 'one-piece-histoire', title: 'Le One Piece est\nnotre histoire', branch: 'temps', certainty: 'moyenne', order: 11 },
    { slug: 'ponelyphes-futur', title: 'Les Ponéglyphes\nracontent le futur', branch: 'temps', certainty: 'central', order: 50 },

    // Identités
    { slug: 'joy-boy', title: 'Joy Boy\n= Luffy', branch: 'identites', certainty: 'central', order: 20 },
    { slug: 'nika', title: 'Nika\n= Luffy', branch: 'identites', certainty: 'central', order: 21 },
    { slug: 'davy-jones', title: 'Davy Jones\n= Teach', branch: 'identites', certainty: 'elevee', order: 40 },
    { slug: 'vivi', title: 'Vivi = Lili', branch: 'identites', certainty: 'elevee', order: 41 },
    { slug: 'ryuma', title: 'Ryuma = Zoro', branch: 'identites', certainty: 'elevee', order: 42 },
    { slug: 'kuma-foi-nika', title: 'Kuma &\nla foi en Nika', branch: 'identites', certainty: 'elevee', order: 22 },

    // Armes
    { slug: 'poseidon', title: 'Poséidon =\nShirahoshi', branch: 'armes', certainty: 'elevee', order: 30 },
    { slug: 'pluton', title: 'Pluton =\nWater Seven', branch: 'armes', certainty: 'moyenne', order: 31 },
    { slug: 'uranus', title: 'Uranus', branch: 'armes', certainty: 'moyenne', order: 32 },

    // Tech
    { slug: 'emeth-futur', title: 'Emeth = BF-39', branch: 'tech', certainty: 'elevee', order: 70 },
    { slug: 'mother-flame', title: 'Mother Flame', branch: 'tech', certainty: 'elevee', order: 71 },
    { slug: 'volonte-heritee', title: 'Volonté héritée', branch: 'tech', certainty: 'elevee', order: 51 },

    // Antagoniste
    { slug: 'imu-nerona', title: 'Imu Nerona', branch: 'antagoniste', certainty: 'elevee', order: 60 },
    { slug: 'vingt-rois-chevaliers-divins', title: 'Les 20 Rois', branch: 'antagoniste', certainty: 'moyenne', order: 61 },

    // Fin
    { slug: 'deluge-all-blue', title: 'Le Déluge &\nAll Blue', branch: 'fin', certainty: 'elevee', order: 80 },
    { slug: 'dieux-one-piece', title: 'Les Dieux de\nOne Piece', branch: 'fin', certainty: 'elevee', order: 100 },
  ];

  // Cross-connections (extra links beyond parent-child)
  const crossLinks = [
    { from: 'joy-boy', to: 'nika', label: 'même personne' },
    { from: 'ponelyphes-futur', to: 'one-piece-histoire', label: 'écrit par Robin' },
    { from: 'deluge-all-blue', to: 'poseidon', label: 'destruction Red Line' },
    { from: 'imu-nerona', to: 'ponelyphes-futur', label: 'a lu les Ponéglyphes' },
    { from: 'emeth-futur', to: 'joy-boy', label: 'reconnaît Joy Boy' },
    { from: 'kuma-foi-nika', to: 'nika', label: 'a fait exister Nika' },
    { from: 'dieux-one-piece', to: 'joy-boy', label: 'Nika = dieu du soleil' },
    { from: 'dieux-one-piece', to: 'ryuma', label: 'dieu des lames' },
  ];

  const certaintyColors: Record<string, string> = {
    central: '#5fb9c2',
    elevee: '#e0ab4e',
    moyenne: '#d98b74',
    hypothese: '#aeb7c2',
  };

  // ─── Compute positions ───────────────────────────────────────
  function toRad(deg: number) { return (deg * Math.PI) / 180; }

  // Branch positions
  const branchPositions: Record<string, { x: number; y: number }> = {};
  for (const b of branches) {
    branchPositions[b.id] = {
      x: CX + Math.cos(toRad(b.angle)) * b.dist,
      y: CY + Math.sin(toRad(b.angle)) * b.dist,
    };
  }

  // Article positions: fan out from their branch
  const nodePositions: Record<string, { x: number; y: number }> = {
    center: { x: CX, y: CY },
  };

  for (const b of branches) {
    const branchArticles = articles.filter(a => a.branch === b.id);
    const count = branchArticles.length;
    const spreadAngle = Math.min(50, 30 + count * 8); // degrees of fan
    const startAngle = b.angle - spreadAngle / 2;
    const step = count > 1 ? spreadAngle / (count - 1) : 0;
    const childDist = 155;

    branchArticles.forEach((a, i) => {
      const angle = count === 1 ? b.angle : startAngle + step * i;
      const bx = branchPositions[b.id].x;
      const by = branchPositions[b.id].y;
      nodePositions[a.slug] = {
        x: bx + Math.cos(toRad(angle)) * childDist,
        y: by + Math.sin(toRad(angle)) * childDist,
      };
    });
  }

  // ─── Render SVG ──────────────────────────────────────────────
  const svg = document.getElementById('mindmap-svg') as unknown as SVGSVGElement;
  const connectionsGroup = document.getElementById('connections') as unknown as SVGGElement;
  const nodesGroup = document.getElementById('nodes') as unknown as SVGGElement;

  function drawConnection(
    x1: number, y1: number,
    x2: number, y2: number,
    color: string,
    dashed: boolean = false,
    opacity: number = 0.35
  ) {
    // Slight curve
    const dx = x2 - x1;
    const dy = y2 - y1;
    const cx1 = x1 + dx * 0.25 + dy * 0.1;
    const cy1 = y1 + dy * 0.25 - dx * 0.1;
    const cx2 = x1 + dx * 0.75 + dy * 0.1;
    const cy2 = y1 + dy * 0.75 - dx * 0.1;

    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path.setAttribute('d', `M${x1},${y1} C${cx1},${cy1} ${cx2},${cy2} ${x2},${y2}`);
    path.setAttribute('fill', 'none');
    path.setAttribute('stroke', color);
    path.setAttribute('stroke-width', dashed ? '1.2' : '2');
    path.setAttribute('stroke-opacity', String(opacity));
    if (dashed) path.setAttribute('stroke-dasharray', '5,4');
    connectionsGroup.appendChild(path);
  }

  // Draw center → branch connections
  for (const b of branches) {
    const bp = branchPositions[b.id];
    drawConnection(CX, CY, bp.x, bp.y, b.color, false, 0.5);
  }

  // Draw branch → article connections
  for (const a of articles) {
    if (a.branch === 'center') continue;
    const bp = branchPositions[a.branch];
    const np = nodePositions[a.slug];
    const branch = branches.find((item) => item.id === a.branch);
    if (bp && np) {
        drawConnection(bp.x, bp.y, np.x, np.y, branch?.color || '#7c8794', false, 0.3);
    }
  }

  // Draw cross-links
  for (const link of crossLinks) {
    const from = nodePositions[link.from];
    const to = nodePositions[link.to];
    if (from && to) {
      drawConnection(from.x, from.y, to.x, to.y, '#7c8794', true, 0.18);
    }
  }

  // ─── Draw nodes ──────────────────────────────────────────────
  function createTextNode(text: string, x: number, y: number, fontSize: number, fill: string, bold: boolean = false) {
    const lines = text.split('\n');
    const lineHeight = fontSize * 1.25;
    const startY = y - ((lines.length - 1) * lineHeight) / 2;

    lines.forEach((line, i) => {
      const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t.setAttribute('x', String(x));
      t.setAttribute('y', String(startY + i * lineHeight));
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('dominant-baseline', 'central');
      t.setAttribute('fill', fill);
      t.setAttribute('font-size', String(fontSize));
      t.setAttribute('font-weight', bold ? '700' : '500');
      t.setAttribute('font-family', 'Inter, sans-serif');
      t.setAttribute('pointer-events', 'none');
      t.textContent = line;
      return t;
    });

    return lines.map((line, i) => {
      const t = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      t.setAttribute('x', String(x));
      t.setAttribute('y', String(startY + i * lineHeight));
      t.setAttribute('text-anchor', 'middle');
      t.setAttribute('dominant-baseline', 'central');
      t.setAttribute('fill', fill);
      t.setAttribute('font-size', String(fontSize));
      t.setAttribute('font-weight', bold ? '700' : '500');
      t.setAttribute('font-family', 'Inter, sans-serif');
      t.setAttribute('pointer-events', 'none');
      t.textContent = line;
      return t;
    });
  }

  // Center node
  {
    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('class', 'mindmap-node mindmap-center-node');
    g.style.cursor = 'pointer';

    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('x', String(CX - 110));
    rect.setAttribute('y', String(CY - 38));
    rect.setAttribute('width', '220');
    rect.setAttribute('height', '76');
    rect.setAttribute('rx', '16');
    rect.setAttribute('fill', '#13202e');
    rect.setAttribute('stroke', '#5fb9c2');
    rect.setAttribute('stroke-width', '2.5');
    rect.setAttribute('filter', 'url(#glow)');
    g.appendChild(rect);

    const texts = createTextNode('Le Siècle oublié\nest le présent', CX, CY, 14, '#5fb9c2', true);
    texts.forEach(t => g.appendChild(t));

    g.addEventListener('click', () => {
      window.location.href = '/theorie/siecle-oublie-present';
    });
    nodesGroup.appendChild(g);
  }

  // Branch nodes (larger, with background)
  for (const b of branches) {
    const bp = branchPositions[b.id];
    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('class', 'mindmap-node mindmap-branch-node');

    const lines = b.label.split('\n');
    const w = Math.max(...lines.map(l => l.length)) * 8.5 + 28;
    const h = lines.length * 20 + 18;

    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('x', String(bp.x - w / 2));
    rect.setAttribute('y', String(bp.y - h / 2));
    rect.setAttribute('width', String(w));
    rect.setAttribute('height', String(h));
    rect.setAttribute('rx', '10');
    rect.setAttribute('fill', b.color + '18');
    rect.setAttribute('stroke', b.color);
    rect.setAttribute('stroke-width', '1.5');
    rect.setAttribute('stroke-opacity', '0.6');
    g.appendChild(rect);

    const texts = createTextNode(b.label, bp.x, bp.y, 12.5, b.color, true);
    texts.forEach(t => g.appendChild(t));

    nodesGroup.appendChild(g);
  }

  // Article nodes (clickable)
  for (const a of articles) {
    if (a.branch === 'center') continue;

    const np = nodePositions[a.slug];
    if (!np) continue;

    const certColor = certaintyColors[a.certainty] || '#7c8794';

    const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
    g.setAttribute('class', 'mindmap-node mindmap-article-node');
    g.style.cursor = 'pointer';

    const lines = a.title.split('\n');
    const w = Math.max(...lines.map(l => l.length)) * 7.5 + 24;
    const h = lines.length * 17 + 14;

    // Background
    const rect = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
    rect.setAttribute('x', String(np.x - w / 2));
    rect.setAttribute('y', String(np.y - h / 2));
    rect.setAttribute('width', String(w));
    rect.setAttribute('height', String(h));
    rect.setAttribute('rx', '6');
    rect.setAttribute('fill', 'rgba(14,23,34,0.85)');
    rect.setAttribute('stroke', certColor);
    rect.setAttribute('stroke-width', '1.5');
    rect.setAttribute('stroke-opacity', '0.7');
    g.appendChild(rect);

    // Certainty dot
    const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
    dot.setAttribute('cx', String(np.x - w / 2 + 8));
    dot.setAttribute('cy', String(np.y - h / 2 + 8));
    dot.setAttribute('r', '3');
    dot.setAttribute('fill', certColor);
    g.appendChild(dot);

    // Text
    const texts = createTextNode(a.title, np.x, np.y, 11, '#f3efe6', false);
    texts.forEach(t => g.appendChild(t));

    // Hover & click
    g.addEventListener('mouseenter', () => {
      rect.setAttribute('stroke-opacity', '1');
      rect.setAttribute('stroke-width', '2.5');
      rect.setAttribute('fill', 'rgba(19,32,46,0.95)');
    });
    g.addEventListener('mouseleave', () => {
      rect.setAttribute('stroke-opacity', '0.7');
      rect.setAttribute('stroke-width', '1.5');
      rect.setAttribute('fill', 'rgba(14,23,34,0.85)');
    });
    g.addEventListener('click', () => {
      window.location.href = `/theorie/${a.slug}`;
    });

    nodesGroup.appendChild(g);
  }

  // ─── Zoom & Pan ──────────────────────────────────────────────
  let scale = 1;
  let panX = 0, panY = 0;
  let isPanning = false;
  let startX = 0, startY = 0;
  const minScale = 0.4;
  const maxScale = 2.5;

  function updateViewBox() {
    const w = 1400 / scale;
    const h = 900 / scale;
    const x = (1400 - w) / 2 + panX;
    const y = (900 - h) / 2 + panY;
    svg.setAttribute('viewBox', `${x} ${y} ${w} ${h}`);
  }

  document.getElementById('zoom-in')?.addEventListener('click', () => {
    scale = Math.min(maxScale, scale * 1.25);
    updateViewBox();
  });
  document.getElementById('zoom-out')?.addEventListener('click', () => {
    scale = Math.max(minScale, scale / 1.25);
    updateViewBox();
  });
  document.getElementById('zoom-reset')?.addEventListener('click', () => {
    scale = 1; panX = 0; panY = 0;
    updateViewBox();
  });

  // Mouse wheel zoom
  const wrapper = document.getElementById('mindmap-wrapper');
  wrapper?.addEventListener('wheel', (e) => {
    e.preventDefault();
    const factor = e.deltaY < 0 ? 1.08 : 0.93;
    scale = Math.max(minScale, Math.min(maxScale, scale * factor));
    updateViewBox();
  }, { passive: false });

  // Pan with mouse drag
  svg.addEventListener('mousedown', (e) => {
    if ((e.target as Element).closest('.mindmap-article-node, .mindmap-center-node')) return;
    isPanning = true;
    startX = e.clientX;
    startY = e.clientY;
    svg.style.cursor = 'grabbing';
  });
  window.addEventListener('mousemove', (e) => {
    if (!isPanning) return;
    const dx = (e.clientX - startX) / scale;
    const dy = (e.clientY - startY) / scale;
    panX -= dx;
    panY -= dy;
    startX = e.clientX;
    startY = e.clientY;
    updateViewBox();
  });
  window.addEventListener('mouseup', () => {
    isPanning = false;
    svg.style.cursor = 'grab';
  });

  // Touch support
  let lastTouchDist = 0;
  let touchStartX = 0, touchStartY = 0;

  wrapper?.addEventListener('touchstart', (e) => {
    if (e.touches.length === 1) {
      isPanning = true;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    } else if (e.touches.length === 2) {
      isPanning = false;
      lastTouchDist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY,
      );
    }
  }, { passive: true });

  wrapper?.addEventListener('touchmove', (e) => {
    if (e.touches.length === 1 && isPanning) {
      const dx = (e.touches[0].clientX - touchStartX) / scale;
      const dy = (e.touches[0].clientY - touchStartY) / scale;
      panX -= dx;
      panY -= dy;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      updateViewBox();
    } else if (e.touches.length === 2) {
      const dist = Math.hypot(
        e.touches[0].clientX - e.touches[1].clientX,
        e.touches[0].clientY - e.touches[1].clientY,
      );
      const factor = dist / lastTouchDist;
      scale = Math.max(minScale, Math.min(maxScale, scale * factor));
      lastTouchDist = dist;
      updateViewBox();
    }
  }, { passive: true });

  wrapper?.addEventListener('touchend', () => {
    isPanning = false;
  }, { passive: true });

  svg.style.cursor = 'grab';
</script>

