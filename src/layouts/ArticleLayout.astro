---
import BaseLayout from './BaseLayout.astro';
import SidebarLeft from '../components/SidebarLeft.astro';
import SidebarRight from '../components/SidebarRight.astro';
import Breadcrumbs, { type Crumb } from '../components/Breadcrumbs.astro';
import Icon from '../components/Icon.astro';
import { certaintyBadges, type Certainty } from '../utils/ui';

/**
 * Layout article — grille trois colonnes sur grand écran :
 * sidebar gauche (272 px) · colonne de lecture (max ~780 px) · sommaire (230 px/230 px).
 * Écran moyen : sidebar + article, sommaire en panneau escamotable.
 * Mobile : article seul, boutons menu et sommaire.
 */

export interface RelatedItem {
  title: string;
  href?: string;
  note?: string;
}

interface Props {
  title: string;
  description: string;
  summary: string;
  breadcrumbs: Crumb[];
  category: string;
  categoryHref?: string;
  certainty?: Certainty;
  spoilerChapter?: number;
  lastUpdatedChapter?: number;
  related?: RelatedItem[];
  /** Masquer le sommaire (articles courts) : la colonne droite disparaît. */
  toc?: boolean;
  /** Affiche la mention « maquette » sous le titre. */
  demo?: boolean;
}

const {
  title,
  description,
  summary,
  breadcrumbs,
  category,
  categoryHref,
  certainty,
  spoilerChapter,
  lastUpdatedChapter,
  related = [],
  toc = true,
  demo = false,
} = Astro.props;

const badge = certainty ? certaintyBadges[certainty] : undefined;
---

<BaseLayout title={`${title} | Les Fous du Bus`} description={description}>
  <div class="mx-auto w-full max-w-[1440px] px-4 sm:px-6 lg:px-8">
    <div
      class:list={[
        'gap-10 lg:grid lg:grid-cols-[272px_minmax(0,1fr)]',
        toc ? 'xl:grid-cols-[272px_minmax(0,1fr)_230px]' : 'xl:grid-cols-[272px_minmax(0,1fr)]',
      ]}
    >
      {/* Sidebar gauche — fixe sous la navbar, défilement indépendant */}
      <aside class="hidden lg:block" aria-label="Navigation du site">
        <div class="sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto pb-10 pr-2 pt-6">
          <SidebarLeft />
        </div>
      </aside>

      {/* Colonne de lecture — 720–820 px, balisée pour l'index Pagefind */}
      <div class="min-w-0">
        <main id="contenu" data-pagefind-body class="article-body mx-auto w-full max-w-[780px] py-8 lg:py-10">
          <Breadcrumbs trail={breadcrumbs} />

          <header class="mt-5">
            {categoryHref ? (
              <a href={categoryHref} class="cat-chip">{category}</a>
            ) : (
              <p class="cat-chip">{category}</p>
            )}

            <h1 class="mt-3 font-display text-3xl font-bold leading-[1.18] text-ink sm:text-[2.6rem] sm:leading-[1.15]">
              {title}
            </h1>

            <p class="lede">{summary}</p>

            <div class="mt-5 flex flex-wrap items-center gap-2">
              {lastUpdatedChapter !== undefined && (
                <span class="meta-chip">
                  <Icon name="clock" class="size-3.5 text-mist/60" />
                  Mis à jour : chapitre {lastUpdatedChapter}
                </span>
              )}
              {spoilerChapter !== undefined && (
                <span class="meta-chip">
                  <Icon name="shield" class="size-3.5 text-mist/60" />
                  Couvre le chapitre {spoilerChapter}
                </span>
              )}
              <span class="meta-chip">
                <Icon name="book" class="size-3.5 text-mist/60" />
                <span data-reading-time>…</span>
              </span>
              {badge && <span class={badge.className}>{badge.label}</span>}
              {demo && (
                <span class="demo-note">
                  <Icon name="sparkles" class="size-3.5" />
                  Maquette d’interface — contenu d’exemple
                </span>
              )}
            </div>
          </header>

          <div class="article-content mt-9">
            <slot />
          </div>

          {related.length > 0 && (
            <footer class="mt-14 border-t border-line pt-8">
              <h2 class="text-base font-semibold text-ink">Poursuivre la lecture</h2>
              <ul class="mt-4 grid gap-3 sm:grid-cols-2">
                {related.map((item) => (
                  <li>
                    {item.href ? (
                      <a href={item.href} class="related-card">
                        <span>
                          {item.title}
                          {item.note && <span class="mt-0.5 block text-xs font-normal text-mist/65">{item.note}</span>}
                        </span>
                        <Icon name="arrow-right" class="size-4 shrink-0 text-mist/50" />
                      </a>
                    ) : (
                      <span class="related-card is-soon" aria-disabled="true">
                        <span>
                          {item.title}
                          {item.note && <span class="mt-0.5 block text-xs font-normal text-mist/65">{item.note}</span>}
                        </span>
                        <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-mist/50">Bientôt</span>
                      </span>
                    )}
                  </li>
                ))}
              </ul>
            </footer>
          )}
        </main>
      </div>

      {/* Sidebar droite — sticky sous la navbar */}
      {toc && (
        <aside class="hidden min-w-0 xl:block" aria-label="Sommaire de l’article">
          <div class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto pb-10 pt-10">
            <SidebarRight listId="toc-list-desktop" lastUpdatedChapter={lastUpdatedChapter} certainty={certainty} />
          </div>
        </aside>
      )}
    </div>
  </div>

  {/* Sommaire escamotable — écrans moyens et mobiles */}
  {toc && (
    <div data-toc-floating>
      <button
        type="button"
        class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 rounded-full border border-line bg-depth/95 py-2.5 pl-4 pr-3.5 text-xs font-semibold text-mist shadow-xl shadow-black/40 backdrop-blur transition hover:border-cyan/50 hover:text-ink xl:hidden"
        data-drawer-open="toc-drawer"
        aria-controls="toc-drawer"
      >
        <Icon name="list" class="size-4" />
        Sommaire
      </button>

      <div id="toc-drawer" class="drawer drawer--right invisible z-[65] xl:hidden" data-drawer>
        <div class="drawer-backdrop" data-drawer-close></div>
        <div
          class="drawer-panel right-0 flex w-[320px] max-w-[86vw] flex-col border-l border-line bg-depth"
          role="dialog"
          aria-modal="true"
          aria-label="Sommaire de l’article"
        >
          <div class="flex h-16 items-center justify-between border-b border-line px-4">
            <span class="text-xs font-bold uppercase tracking-[0.18em] text-mist/70">Sommaire</span>
            <button type="button" class="btn-icon" data-drawer-close aria-label="Fermer le sommaire">
              <Icon name="x" />
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-4">
            <SidebarRight listId="toc-list-mobile" lastUpdatedChapter={lastUpdatedChapter} certainty={certainty} />
          </div>
        </div>
      </div>
    </div>
  )}

  <script>
    import '../scripts/article';
  </script>
</BaseLayout>
