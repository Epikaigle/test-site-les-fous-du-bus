---
import WikiLayout from '@layouts/WikiLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import ArticleMeta from '@components/ArticleMeta.astro';
import RelatedArticles from '@components/RelatedArticles.astro';
import EvidenceSection from '@components/EvidenceSection.astro';
import ChapterReferences from '@components/ChapterReferences.astro';
import Footer from '@components/Footer.astro';
import { certaintyToFrench } from '@utils/format';
import { getCollection } from 'astro:content';

const {
  title,
  description,
  currentPath,
  headings,
  frontmatter,
  readingTime = '1 min',
} = Astro.props;
const certainty = certaintyToFrench(frontmatter.certainty);
const lastUpdatedChapter = String(frontmatter.lastUpdatedChapter ?? '?');

// Fetch related articles from the articles collection
const allArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const currentSlug = currentPath.replace('/theorie/', '');
const relatedArticleEntries = allArticles.filter((a) =>
  frontmatter.related?.includes(a.id) && a.id !== currentSlug
);
const relatedArticles = relatedArticleEntries.map((entry) => ({
  title: entry.data.title,
  href: `/theorie/${entry.id}`,
  category: entry.data.category,
}));

// Fetch evidence related to this article
const evidenceEntries = await getCollection('evidence');
const articleEvidence = evidenceEntries.filter((e) =>
  e.data.articles?.includes(currentSlug)
);

// Fetch chapter references related to this article
const chapterEntries = await getCollection('chapters');
const articleChapters = chapterEntries.filter((c) =>
  c.data.updatedArticles?.includes(currentSlug)
);

const breadcrumbItems = [
  { label: 'Accueil', href: '/' },
  { label: 'La théorie', href: '/theorie' },
  { label: title },
];

// JSON-LD for Article
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  url: new URL(currentPath, Astro.site).toString(),
  datePublished: frontmatter.lastUpdatedChapter ? new Date().toISOString() : undefined,
  author: {
    '@type': 'Organization',
    name: 'Les Fous du Bus'
  },
  publisher: {
    '@type': 'Organization',
    name: 'Les Fous du Bus',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).toString()
    }
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(currentPath, Astro.site).toString()
  }
};
---

<WikiLayout title={title} description={description} currentPath={currentPath} headings={headings}>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />

  <Breadcrumb items={breadcrumbItems} />

  <article data-pagefind-body>
    <h1 class="article-title">{title}</h1>
    {description && <p class="article-lead">{description}</p>}
    <ArticleMeta
      certainty={certainty}
      lastUpdatedChapter={lastUpdatedChapter}
      readingTime={readingTime}
    />

    <div class="content">
      <slot />
    </div>
  </article>

  {articleEvidence.length > 0 && <EvidenceSection items={articleEvidence} />}
  {articleChapters.length > 0 && <ChapterReferences items={articleChapters} />}
  {relatedArticles.length > 0 && <RelatedArticles articles={relatedArticles} />}

  <Footer />
</WikiLayout>

<style>
  .article-title {
    font-size: clamp(1.8rem, 4.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 12px;
    line-height: 1.15;
    letter-spacing: -0.03em;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .article-lead {
    font-size: 16px;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 8px;
  }

  .content {
    margin-top: 32px;
    line-height: 1.8;
    font-size: 16px;
  }

  .content :global(h2) {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    position: relative;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .content :global(h2::before) {
    content: '';
    display: inline-block;
    width: 18px;
    height: 3px;
    border-radius: 2px;
    background: var(--gradient-border);
    flex-shrink: 0;
  }

  .content :global(h3) {
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content :global(p) {
    margin-bottom: 1.1rem;
  }

  .content :global(strong) {
    color: var(--text-main);
    font-weight: 600;
  }

  .content :global(a) {
    color: var(--cyan);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--cyan) 30%, transparent);
    transition: text-decoration-color 0.2s ease;
  }

  .content :global(a:hover) {
    text-decoration-color: var(--cyan);
  }

  .content :global(img) {
    border-radius: 10px;
    margin: 1.5rem 0;
    border: 1px solid var(--border-color);
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--violet);
    padding: 12px 16px;
    margin: 1.5rem 0;
    color: var(--text-secondary);
    font-style: italic;
    background: color-mix(in srgb, var(--violet) 5%, transparent);
    border-radius: 0 8px 8px 0;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.1rem;
  }

  .content :global(li) {
    margin-bottom: 0.35rem;
  }

  .content :global(li::marker) {
    color: var(--violet-light);
  }

  .content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 14px;
    overflow-x: auto;
    display: block;
    border-radius: 8px;
    border: 1px solid var(--border-color);
  }

  .content :global(th),
  .content :global(td) {
    padding: 10px 14px;
    border: 1px solid var(--border-color);
    text-align: left;
  }

  .content :global(th) {
    background-color: var(--surface);
    font-weight: 600;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .content :global(hr) {
    border: none;
    height: 1px;
    background: var(--gradient-border);
    margin: 2rem 0;
    opacity: 0.4;
  }

  .content :global(code) {
    background: var(--surface);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  @media (max-width: 480px) {
    .content {
      margin-top: 24px;
      font-size: 15px;
    }
  }
</style>
