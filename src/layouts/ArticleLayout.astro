---
import WikiLayout from '@layouts/WikiLayout.astro';
import Breadcrumb from '@components/Breadcrumb.astro';
import ArticleMeta from '@components/ArticleMeta.astro';
import RelatedArticles from '@components/RelatedArticles.astro';
import EvidenceSection from '@components/EvidenceSection.astro';
import ChapterReferences from '@components/ChapterReferences.astro';
import Footer from '@components/Footer.astro';

const { title, description, currentPath, headings, frontmatter } = Astro.props;

const breadcrumbItems = [
  { label: 'Accueil', href: '/' },
  { label: 'La théorie', href: '/theorie' },
  { label: title }
];
---

<WikiLayout title={title} description={description} currentPath={currentPath} headings={headings}>
    <Breadcrumb items={breadcrumbItems} />
    
    <main data-pagefind-body>
        <h1 class="article-title">{title}</h1>
        <ArticleMeta frontmatter={frontmatter} />
        
        <div class="content">
            <slot />
        </div>
    </main>

    <EvidenceSection />
    <ChapterReferences />
    <RelatedArticles articles={[]} />
    
    <Footer />
</WikiLayout>

<style>
    .article-title {
        font-size: clamp(1.5rem, 4vw, 2.2rem);
        font-weight: 700;
        margin-bottom: 16px;
        line-height: 1.2;
        letter-spacing: -0.02em;
    }

    .content {
        margin-top: 32px;
        line-height: 1.7;
    }

    /* Minimal default styles for markdown content */
    .content :global(h2) {
        font-size: clamp(1.2rem, 3vw, 1.5rem);
        margin-top: 2rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 0.5rem;
    }
    
    .content :global(h3) {
        font-size: clamp(1.05rem, 2.5vw, 1.25rem);
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
    }
    
    .content :global(p) {
        margin-bottom: 1rem;
    }
    
    .content :global(a) {
        color: var(--cyan);
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .content :global(img) {
        border-radius: 8px;
        margin: 1rem 0;
    }

    .content :global(blockquote) {
        border-left: 3px solid var(--violet);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--text-secondary);
        font-style: italic;
    }

    .content :global(ul),
    .content :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .content :global(li) {
        margin-bottom: 0.25rem;
    }

    .content :global(table) {
        width: 100%;
        border-collapse: collapse;
        margin: 1rem 0;
        font-size: 14px;
        overflow-x: auto;
        display: block;
    }

    .content :global(th),
    .content :global(td) {
        padding: 8px 12px;
        border: 1px solid var(--border-color);
        text-align: left;
    }

    .content :global(th) {
        background-color: var(--surface);
        font-weight: 600;
    }

    @media (max-width: 480px) {
        .content {
            margin-top: 24px;
        }
    }
</style>
