---
import BaseLayout from '@layouts/BaseLayout.astro';
import SidebarNav from '@components/SidebarNav.astro';
import SidebarToc from '@components/SidebarToc.astro';
import Navbar from '@components/Navbar.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  currentPath: string;
  headings?: Heading[];
}

const { title, description, currentPath, headings } = Astro.props;

// Pages without headings must not reserve an empty 240px gutter
// or show a "Sommaire" drawer with no entries.
const hasToc = !!(headings && headings.length > 0);
---

<BaseLayout title={title} description={description}>
  <script is:inline>
    (function() {
      const collapsed = localStorage.getItem('sidebar-left-collapsed') === 'true';
      if (collapsed) {
        document.documentElement.classList.add('sidebar-left-collapsed');
      }
      const storedWidth = localStorage.getItem('sidebar-left-width');
      if (storedWidth && !collapsed) {
        document.documentElement.style.setProperty('--sidebar-left-width', storedWidth);
      }
    })();
  </script>

  <Navbar />

  <div class:list={['layout', { 'layout--no-toc': !hasToc }]}>
    <div class="sidebar-left-container" id="sidebar-left-container">
      <aside class="sidebar sidebar-left" id="sidebar-left">
        <SidebarNav currentPath={currentPath} />
      </aside>

      <!-- Vertical Resizer Handle for mouse drag width adjustment -->
      <div id="sidebar-resizer" class="sidebar-resizer" title="Glisser pour redimensionner la barre latérale" aria-label="Redimensionner la barre latérale"></div>
    </div>

    <main class="main-content" id="main-content">
      <slot />
    </main>

    {
      hasToc && (
        <aside class="sidebar sidebar-right">
          <SidebarToc headings={headings} />
        </aside>
      )
    }
  </div>

  {/* Floating TOC button for tablet/mobile (only when a TOC exists) */}
</BaseLayout>

<style>
  .layout {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) 240px;
    flex: 1;
    width: 100%;
  }

  /* Pages without a table of contents: no empty 240px gutter */
  .layout--no-toc {
    grid-template-columns: auto minmax(0, 1fr);
  }

  .sidebar-left-container {
    position: relative;
    width: var(--sidebar-left-width, 260px);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .sidebar-left-container.collapsed,
  :global(.sidebar-left-collapsed) .sidebar-left-container {
    --sidebar-left-width: 0px !important;
  }

  /* Header inside sidebar containing title & collapse button */
  .sidebar-left-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 12px;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
  }

  .sidebar-left-title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sidebar-collapse-btn {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--surface) 60%, transparent);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .sidebar-collapse-btn:hover {
    background: var(--surface);
    color: var(--cyan);
    border-color: var(--cyan);
    transform: scale(1.08);
  }

  /* Expand button visible on left margin when collapsed */
  .sidebar-expand-btn {
    position: fixed;
    top: calc(var(--nav-h) + 16px);
    left: 12px;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    display: none;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 45;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
    transition: all 0.2s ease;
  }

  .sidebar-expand-btn:hover {
    color: var(--cyan);
    border-color: var(--cyan);
    box-shadow: 0 0 12px var(--glow-cyan);
    transform: scale(1.08);
  }

  :global(.sidebar-left-collapsed) .sidebar-expand-btn {
    display: flex;
  }

  /* Resizer handle on the right edge of sidebar-left */
  .sidebar-resizer {
    position: absolute;
    top: 0;
    right: -4px;
    width: 8px;
    height: 100%;
    cursor: col-resize;
    z-index: 40;
    touch-action: none;
  }

  .sidebar-resizer::after {
    content: '';
    position: absolute;
    top: 0;
    left: 3px;
    width: 2px;
    height: 100%;
    background-color: transparent;
    transition: background-color 0.2s ease;
  }

  .sidebar-resizer:hover::after,
  :global(body.is-resizing) .sidebar-resizer::after {
    background-color: var(--cyan);
    box-shadow: 0 0 8px var(--glow-cyan);
  }

  :global(.sidebar-left-collapsed) .sidebar-resizer {
    display: none;
  }

  :global(body.is-resizing) {
    user-select: none !important;
    cursor: col-resize !important;
  }

  :global(body.is-resizing) .sidebar-left-container,
  :global(body.is-resizing) .sidebar-left {
    transition: none !important;
  }

  .sidebar {
    padding: 24px 16px;
    height: calc(100vh - var(--nav-h));
    position: sticky;
    top: var(--nav-h);
    overflow-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    box-sizing: border-box;
  }

  .sidebar::-webkit-scrollbar {
    display: none;
  }

  .sidebar-left {
    width: var(--sidebar-left-width, 260px);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bg-secondary) 30%, transparent) 0%,
      transparent 100%
    );
  }

  .sidebar-left-container.collapsed .sidebar-left,
  :global(.sidebar-left-collapsed) .sidebar-left-container .sidebar-left {
    transform: translateX(-100%);
    opacity: 0;
    pointer-events: none;
  }

  .sidebar-right {
    width: 240px;
    border-left: 1px solid var(--border-color);
  }

  .main-content {
    padding: 32px 40px;
    max-width: 860px;
    width: 100%;
    margin: 0 auto;
    min-width: 0;
  }

  /* Floating TOC button - hidden on desktop where sidebar-right is visible */
  /* Tablet: hide right sidebar */
  @media (max-width: 1200px) {
    .sidebar-right {
      display: none;
    }
    .layout {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }

  /* Mobile: hide left sidebar, single column */
  @media (max-width: 768px) {
    .sidebar-left-container {
      display: none;
    }
    .layout {
      grid-template-columns: 1fr;
    }
    .main-content {
      padding: 24px 16px;
    }
  }

  /* Small mobile */
  @media (max-width: 480px) {
    .main-content {
      padding: 20px 12px;
    }
  }
</style>

<script>

  // Close TOC on resize to desktop
  window.addEventListener('resize', () => {
    if (window.innerWidth > 1200 && isTocOpen()) {
      closeToc();
    }
  });

  // Left sidebar collapse / expand logic controlled by the single navbar button
  const navbarSidebarToggle = document.getElementById('navbar-sidebar-toggle');
  const sidebarContainer = document.getElementById('sidebar-left-container');

  const toggleSidebar = () => {
    const isCollapsed = !document.documentElement.classList.contains('sidebar-left-collapsed');
    if (isCollapsed) {
      document.documentElement.classList.add('sidebar-left-collapsed');
      sidebarContainer?.classList.add('collapsed');
    } else {
      document.documentElement.classList.remove('sidebar-left-collapsed');
      sidebarContainer?.classList.remove('collapsed');
    }
    localStorage.setItem('sidebar-left-collapsed', String(isCollapsed));
  };

  navbarSidebarToggle?.addEventListener('click', toggleSidebar);

  // Sidebar drag resizer logic
  const resizer = document.getElementById('sidebar-resizer');
  const MIN_WIDTH = 200;
  const MAX_WIDTH = 480;

  if (resizer) {
    let isDragging = false;

    const startDragging = (e: MouseEvent | TouchEvent) => {
      if (document.documentElement.classList.contains('sidebar-left-collapsed')) return;
      isDragging = true;
      document.body.classList.add('is-resizing');
      e.preventDefault();
    };

    const onMove = (e: MouseEvent | TouchEvent) => {
      if (!isDragging) return;
      const clientX = 'touches' in e ? e.touches[0].clientX : e.clientX;
      const newWidth = Math.min(MAX_WIDTH, Math.max(MIN_WIDTH, clientX));
      document.documentElement.style.setProperty('--sidebar-left-width', `${newWidth}px`);
    };

    const stopDragging = () => {
      if (!isDragging) return;
      isDragging = false;
      document.body.classList.remove('is-resizing');
      const currentWidth = getComputedStyle(document.documentElement)
        .getPropertyValue('--sidebar-left-width')
        .trim();
      if (currentWidth && currentWidth !== '0px') {
        localStorage.setItem('sidebar-left-width', currentWidth);
      }
    };

    resizer.addEventListener('mousedown', startDragging);
    resizer.addEventListener('touchstart', startDragging, { passive: false });

    window.addEventListener('mousemove', onMove);
    window.addEventListener('touchmove', onMove, { passive: false });

    window.addEventListener('mouseup', stopDragging);
    window.addEventListener('touchend', stopDragging);
  }
</script>
